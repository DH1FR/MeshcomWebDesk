@page "/clear"
@rendermode InteractiveServer
@inject ChatService ChatService
@inject DataPersistenceService PersistenceService
@inject MeshcomWebDesk.Services.LanguageService Loc
@implements IDisposable

<PageTitle>@Loc.T("Daten löschen", "Clear Data", "Elimina dati", "Borrar datos") – MeshCom WebDesk</PageTitle>

<div class="about-page">
    <div class="about-card clear-card">
        <div class="about-icon">🗑️</div>
        <h1 class="about-title">@Loc.T("Daten löschen", "Clear Data", "Elimina dati", "Borrar datos")</h1>

        <div class="about-divider"></div>

        @if (_done)
        {
            <p class="clear-success">✅ @Loc.T("Alle Daten wurden gelöscht.", "All data has been deleted.", "Tutti i dati sono stati eliminati.", "Todos los datos han sido eliminados.")</p>
            <p class="clear-hint">@Loc.T("Die Datei auf der Disk wurde ebenfalls geleert.", "The file on disk was also cleared.", "Anche il file su disco è stato svuotato.", "El archivo en disco también fue vaciado.")</p>
        }
        else if (_confirm)
        {
            <p class="clear-warning">
                ⚠️ @Loc.T("Alle Chat-Nachrichten, Monitor-Einträge und die MH-Liste werden", "All chat messages, monitor entries and the MH list will be", "Tutti i messaggi chat, le voci del monitor e la lista MH verranno", "Todos los mensajes de chat, entradas del monitor y la lista MH serán")
                <strong>@Loc.T("unwiderruflich", "permanently", "definitivamente", "permanentemente")</strong>
                @Loc.T("gelöscht. Fortfahren?", "deleted. Continue?", "eliminati. Continuare?", "¿Continuar?")
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="ExecuteClear">@Loc.T("Ja, alles löschen", "Yes, delete everything", "Sì, elimina tutto", "Sí, eliminar todo")</button>
                <button class="btn-cancel" @onclick="() => _confirm = false">@Loc.T("Abbrechen", "Cancel", "Annulla", "Cancelar")</button>
            </div>
        }
        else
        {
            <p class="about-description">
                @Loc.T("Löscht alle gespeicherten Daten:", "Deletes all stored data:", "Elimina tutti i dati salvati:", "Elimina todos los datos guardados:")<br />
                @Loc.T("Chat-Tabs &amp; Nachrichten · MH-Liste · Monitor-Feed", "Chat tabs &amp; messages · MH list · monitor feed", "Schede chat &amp; messaggi · Lista MH · Feed monitor", "Pestañas de chat &amp; mensajes · Lista MH · Feed monitor")
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="() => _confirm = true">@Loc.T("Alle Daten löschen …", "Delete all data …", "Elimina tutti i dati …", "Eliminar todos los datos …")</button>
            </div>
        }
    </div>
</div>

@code {
    private bool _confirm;
    private bool _done;

    protected override void OnInitialized() => Loc.OnChange += StateHasChanged;
    public void Dispose() => Loc.OnChange -= StateHasChanged;

    private async Task ExecuteClear()
    {
        ChatService.ClearAllData();
        await PersistenceService.SaveAsync();
        _confirm = false;
        _done    = true;
    }
}
