@page "/mh"
@rendermode InteractiveServer
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using MeshcomWebDesk.Helpers
@using Microsoft.Extensions.Options
@implements IDisposable
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject IOptions<MeshcomSettings> SettingsOptions
@inject LanguageService Loc

<PageTitle>MH – @Loc.T("Zuletzt gehört", "Most Recently Heard", "Più recenti", "Más recientes")</PageTitle>

<div class="mh-page">

    @* ── Own position bar ── *@
    <div class="mh-ownpos @(HasOwnPos ? "mh-ownpos-ok" : "mh-ownpos-unknown")">
        <span class="mh-ownpos-label">📍 @Loc.T("Eigene Position:", "Own Position:", "Posizione propria:", "Posición propia:")</span>
        @if (HasOwnPos)
        {
            <span class="mh-ownpos-val">
                @GeoHelper.FormatCoord(_status.OwnLatitude, _status.OwnLongitude)
                @if (_status.OwnAltitude.HasValue)
                { <span class="mh-ownpos-alt">&nbsp;· @_status.OwnAltitude m ü.NN</span> }
            </span>
            <span class="mh-ownpos-src">[Node]</span>
            <a class="mh-osm-link" href="@GeoHelper.OsmUrl(_status.OwnLatitude!.Value, _status.OwnLongitude!.Value)"
               target="_blank" title="@Loc.T("Auf Karte anzeigen", "Show on map", "Mostra sulla mappa", "Mostrar en el mapa")">&#x1f5fa;&#xfe0f;</a>
        }
        else
        {
            <span class="mh-ownpos-unknown-txt">⏳ @Loc.T($"Warte auf Positionsdaten vom Node ({_myCallsign})…", $"Waiting for position data from node ({_myCallsign})…", $"In attesa di dati di posizione dal nodo ({_myCallsign})…", $"Esperando datos de posición del nodo ({_myCallsign})…")</span>
        }
    </div>

    @* ── Header ── *@
    <div class="mh-header">
        <div class="mh-title-row">
            <h2 class="mh-title">📻 Most Recently Heard</h2>
            <span class="mh-subtitle">@_stations.Count @Loc.T("Station", "Station", "Station", "Station")@(_stations.Count != 1 ? Loc.T("en", "s", "s", "s") : "")</span>
        </div>
        @if (_stations.Count > 0)
        {
            <button class="mh-clear-btn" @onclick="ClearList">🗑️ @Loc.T("Liste leeren", "Clear List", "Svuota lista", "Vaciar lista")</button>
        }
    </div>

    @* ── Table ── *@
    @if (_stations.Count == 0)
    {
        <div class="mh-empty">
            <p>@Loc.T("Noch keine Stationen gehört.", "No stations heard yet.", "Nessuna stazione ricevuta.", "Ninguna estación escuchada aún.")</p>
            <p class="mh-empty-hint">@Loc.T("Empfangene LoRa-Nachrichten erscheinen hier automatisch.", "Received LoRa messages will appear here automatically.", "I messaggi LoRa ricevuti appariranno qui automaticamente.", "Los mensajes LoRa recibidos aparecerán aquí automáticamente.")</p>
        </div>
    }
    else
    {
        <div class="mh-table-wrapper">
            <table class="mh-table">
                <thead>
                    <tr>
                        <th>@Loc.T("Rufzeichen", "Callsign", "Nominativo", "Indicativo")</th>
                        <th>@Loc.T("Zuletzt gehört", "Last Heard", "Ultima ricezione", "último recibido")</th>
                        <th class="col-center">@Loc.T("Anz.", "Cnt.", "N.", "N.")</th>
                        <th>@Loc.T("Letzte Nachricht", "Last Message", "Ultimo messaggio", "último mensaje")</th>
                        <th>@Loc.T("GPS-Position", "GPS Position", "Posizione GPS", "Posición GPS")</th>
                        <th class="col-center">@Loc.T("Höhe", "Alt.", "Alt.", "Alt.")</th>
                        <th class="col-center">@Loc.T("Entfernung", "Distance", "Distanza", "Distancia")</th>
                        <th class="col-center">🔋</th>
                        <th class="col-center">RSSI</th>
                        <th class="col-center">SNR</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _stations)
                    {
                        var dist = CalcDistance(s);
                        <tr class="mh-row">
                            <td class="mh-callsign">
                                <span title="@BuildStationTooltip(s, Loc.T("Erstmals", "First", "Prima volta", "Primera vez"))">@s.Callsign</span>
                                @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(s.HwId)))
                                {
                                    <span class="mh-hw-badge">@MeshcomLookup.HwName(s.HwId)</span>
                                }
                            </td>
                            <td class="mh-time">
                                <span class="mh-date">@s.LastHeard.ToString("dd.MM.yy")</span>
                                <span class="mh-hour">@s.LastHeard.ToString("HH:mm:ss")</span>
                            </td>
                            <td class="col-center mh-count-cell">@s.MessageCount</td>
                            <td class="mh-msg">@Truncate(s.LastMessage, 35)</td>
                            <td class="mh-pos">
                                @if (s.Latitude.HasValue && s.Longitude.HasValue)
                                {
                                    <a class="mh-coord-link"
                                       href="@GeoHelper.OsmUrl(s.Latitude.Value, s.Longitude.Value)"
                                          target="_blank"
                                          title="@Loc.T("Auf Karte anzeigen", "Show on map", "Mostra sulla mappa", "Mostrar en el mapa")">
                                        @($"{s.Latitude.Value:F4}°{(s.Latitude >= 0 ? "N" : "S")}")
                                        <br />
                                        @($"{s.Longitude.Value:F4}°{(s.Longitude >= 0 ? "E" : "W")}")
                                    </a>
                                }
                                else
                                {
                                    <span class="mh-no-pos">–</span>
                                }
                            </td>
                            <td class="col-center mh-alt">
                                @(s.Altitude.HasValue ? $"{s.Altitude} m" : "–")
                            </td>
                            <td class="col-center mh-dist @(dist.HasValue ? "dist-known" : "")">
                                @(dist.HasValue ? GeoHelper.FormatDistance(dist.Value) : "–")
                            </td>
                            <td class="col-center mh-batt">
                                @if (s.Battery.HasValue)
                                {
                                    <span class="@BattClass(s.Battery.Value)" title="@Loc.T($"Akku {s.Battery}%", $"Battery {s.Battery}%", $"Batteria {s.Battery}%", $"Bateriía {s.Battery}%")">@s.Battery%</span>
                                }
                                else
                                {
                                    <span class="mh-no-pos">–</span>
                                }
                            </td>
                            <td class="col-center @RssiClass(s.LastRssi)">
                                @(s.LastRssi.HasValue ? $"{s.LastRssi} dBm" : "–")
                            </td>
                            <td class="col-center @RssiClass(s.LastRssi)">
                                @(s.LastSnr.HasValue ? $"{s.LastSnr:F1} dB" : "–")
                            </td>
                            <td>
                                <button class="mh-chat-btn" @onclick="() => OpenChat(s.Callsign)"
                                        title="@Loc.T($"Chat mit {s.Callsign} öffnen", $"Open chat with {s.Callsign}", $"Apri chat con {s.Callsign}", $"Abrir chat con {s.Callsign}")">&#x1f4ac;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IReadOnlyList<HeardStation> _stations = [];
    private ConnectionStatus _status = new();
    private string _myCallsign = string.Empty;
    private bool _disposed;

    private bool HasOwnPos => _status.OwnLatitude.HasValue && _status.OwnLongitude.HasValue;

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
        _myCallsign = SettingsOptions.Value.MyCallsign;
        _status     = UdpService.Status;
        _stations   = ChatService.MhList;
        ChatService.OnChange      += OnChanged;
        UdpService.OnStatusChange += OnStatusChanged;
    }

    private async void OnChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _stations = ChatService.MhList;
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private async void OnStatusChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _status = UdpService.Status;
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private double? CalcDistance(HeardStation s)
    {
        if (!HasOwnPos || !s.Latitude.HasValue || !s.Longitude.HasValue)
            return null;
        return GeoHelper.CalculateDistanceKm(
            _status.OwnLatitude!.Value, _status.OwnLongitude!.Value,
            s.Latitude.Value, s.Longitude.Value);
    }

    private void OpenChat(string callsign)
    {
        ChatService.OpenTab(callsign.ToUpperInvariant());
    }

    private void ClearList() => ChatService.ClearMhList();

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "…";

    private static string RssiClass(int? rssi) => rssi switch
    {
        > -70 => "rssi-good",
        > -90 => "rssi-fair",
        null  => "",
        _     => "rssi-weak"
    };

    private static string BattClass(int batt) => batt switch
    {
        > 60 => "batt-ok",
        > 30 => "batt-warn",
        _    => "batt-low"
    };

    private static string BuildStationTooltip(HeardStation s, string firstLabel)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(s.Firmware))      parts.Add($"FW: {s.Firmware}");
        if (s.HwId.HasValue)                         parts.Add($"HW-ID: {s.HwId}");
        if (s.FirstHeard != default)                 parts.Add($"{firstLabel}: {s.FirstHeard:dd.MM.yy HH:mm}");
        return parts.Count > 0 ? string.Join(" | ", parts) : s.Callsign;
    }

    public void Dispose()
    {
        _disposed = true;
        Loc.OnChange      -= StateHasChanged;
        ChatService.OnChange      -= OnChanged;
        UdpService.OnStatusChange -= OnStatusChanged;
    }
}
