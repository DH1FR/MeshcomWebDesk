@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@using MeshcomWebDesk.Services.Database
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject SettingsService SettingsService
@inject MeshcomUdpService UdpService
@inject LanguageService Loc
@inject DatabaseSetupService DatabaseSetupService
@inject QrzService QrzService
@implements IDisposable

<PageTitle>@Loc.T("Einstellungen", "Settings", "Impostazioni", "Configuración") – MeshCom WebDesk</PageTitle>

<div class="settings-page">
    <div class="settings-container">

        <div class="settings-header">
            <span class="settings-icon">⚙️</span>
            <h1 class="settings-title">@Loc.T("Einstellungen", "Settings", "Impostazioni", "Configuración")</h1>
        </div>

        <div class="settings-notice">
            ℹ️ @Loc.T("Die meisten Einstellungen werden", "Most settings are applied", "La maggior parte delle impostazioni vengono", "La mayoría de los ajustes se aplican")
            <strong>@Loc.T("sofort", "immediately", "immediatamente", "inmediatamente")</strong>
            @Loc.T("übernommen, ohne Neustart.", "without a restart.", "applicate senza riavvio.", "sin reiniciar.")<br />
            @Loc.T("Ausnahmen:", "Exceptions:", "Eccezioni:", "Excepciones:")
            <strong>Listen-IP / Listen-Port</strong>
            @Loc.T("(Socket-Binding) und", "(socket binding) and", "(binding socket) e", "(binding de socket) y")
            <strong>@Loc.T("Log-Pfad / Log-Aufbewahrung", "Log Path / Log Retention", "Percorso / Conservazione Log", "Ruta / Retención de Log")</strong>
            @Loc.T("(Serilog) erfordern einen Neustart der Anwendung.", "(Serilog) require an application restart.", "(Serilog) richiedono il riavvio dell'app.", "(Serilog) requieren reiniciar la aplicación.")
        </div>

        @if (_saved)
        {
            <div class="settings-success">✅ @Loc.T("Einstellungen gespeichert.", "Settings saved.", "Impostazioni salvate.", "Ajustes guardados.")</div>
        }
        @if (_errorMessage != null)
        {
            <div class="settings-error">❌ @Loc.T("Fehler:", "Error:", "Errore:", "Error:") @_errorMessage</div>
        }

        <!-- Verbindung / Connection -->
        <div class="settings-section">
            <h2 class="settings-section-title">🔌 @Loc.T("Verbindung", "Connection", "Connessione", "Conexión")</h2>
            <div class="settings-grid">
                <label>Listen IP</label>
                <input type="text" @bind="_model.ListenIp" />

                <label>Listen Port</label>
                <input type="number" min="1" max="65535" @bind="_model.ListenPort" />

                <label>Device IP</label>
                <input type="text" @bind="_model.DeviceIp" />

                <label>Device Port</label>
                <input type="number" min="1" max="65535" @bind="_model.DevicePort" />

                <label>@Loc.T("Eigenes Rufzeichen", "Own Callsign", "Nominativo", "Indicativo propio")</label>
                <input type="text" @bind="_model.MyCallsign" />
            </div>
            <a class="settings-help-banner"
               href="@($"https://github.com/DH1FR/MeshcomWebDesk/blob/master/docs/node-connection-{Loc.Current}.md")"
               target="_blank" rel="noopener">
                ❓ @Loc.T(
                    "Wie konfiguriere ich meinen MeshCom-Node für WebDesk?",
                    "How do I configure my MeshCom node for WebDesk?",
                    "Come configuro il mio nodo MeshCom per WebDesk?",
                    "¿Cómo configuro mi nodo MeshCom para WebDesk?")
                <span class="settings-help-banner-arrow">→</span>
            </a>
        </div>

        <!-- Logging -->
        <div class="settings-section">
            <h2 class="settings-section-title">📝 Logging</h2>
            <div class="settings-grid">
                <label>@Loc.T("Log-Pfad", "Log Path", "Percorso Log", "Ruta de Log")</label>
                <input type="text" @bind="_model.LogPath" />

                <label>@Loc.T("Log-Aufbewahrung (Tage)", "Log Retention (Days)", "Conservazione Log (giorni)", "Retención de Log (días)")</label>
                <input type="number" min="1" @bind="_model.LogRetainDays" />

                <label>
                    @Loc.T("UDP-Traffic loggen", "Log UDP Traffic", "Registra traffico UDP", "Registrar tráfico UDP")
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.LogUdpTraffic" />
                    <span>@(_model.LogUdpTraffic ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>
            </div>
        </div>

        <!-- Chat & Monitor -->
        <div class="settings-section">
            <h2 class="settings-section-title">💬 Chat &amp; Monitor</h2>
            <div class="settings-grid">
                <label>@Loc.T("Monitor-Limit (Einträge)", "Monitor Limit (Entries)", "Limite monitor (voci)", "Límite monitor (entradas)")</label>
                <input type="number" min="10" @bind="_model.MonitorMaxMessages" />

                <label>
                    @Loc.T("Zeitversatz (Stunden)", "Time Offset (Hours)", "Offset orario (ore)", "Desfase horario (horas)")<br />
                    <small>@Loc.T("UTC-Korrektur für Zeitanzeige, z.\u00a0B. 1 für MEZ, 2 für MESZ, 0 wenn Zeitzone bereits korrekt", "UTC offset for time display, e.\u00a0g. 1 for CET, 2 for CEST, 0 if timezone already correct", "Offset UTC per visualizzazione, es. 1 per CET, 2 per CEST", "Desfase UTC para visualización, p.ej. 1 para CET, 2 para CEST")</small>
                </label>
                <input type="number" step="0.5" @bind="_model.TimeOffsetHours" />

                <label>@Loc.T("Gruppenfilter aktiv", "Group Filter Active", "Filtro gruppi attivo", "Filtro de grupos activo")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.GroupFilterEnabled" />
                    <span>@(_model.GroupFilterEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>
                    @Loc.T("Gruppen-Whitelist", "Group Whitelist", "Whitelist gruppi", "Lista blanca de grupos")<br />
                    <small>@Loc.T("(eine pro Zeile, z.\u00a0B. #262)", "(one per line, e.\u00a0g. #262)", "(uno per riga, es. #262)", "(uno por línea, p.ej. #262)")</small>
                </label>
                <textarea rows="4" @bind="_model.GroupsText"></textarea>
            </div>
        </div>

        <!-- Datenspeicherung / Data Storage -->
        <div class="settings-section">
            <h2 class="settings-section-title">💾 @Loc.T("Datenspeicherung", "Data Storage", "Archiviazione dati", "Almacenamiento de datos")</h2>
            <div class="settings-grid">
                <label>@Loc.T("Datenpfad", "Data Path", "Percorso dati", "Ruta de datos")</label>
                <input type="text" @bind="_model.DataPath" />
            </div>
        </div>

        <!-- Auto-Reply -->
        <div class="settings-section">
            <h2 class="settings-section-title">↩️ Auto-Reply</h2>
            <div class="settings-grid">
                <label>@Loc.T("Auto-Reply aktiv", "Auto-Reply Active", "Auto-risposta attiva", "Auto-respuesta activa")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.AutoReplyEnabled" />
                    <span>@(_model.AutoReplyEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>Auto-Reply Text</label>
                <div class="settings-input-hint">
                    <input type="text" @bind="_model.AutoReplyText" />
                    <span class="settings-hint">@Loc.T(
                        "{version} = Version · {mycall} = eigenes Rufzeichen · {callsign} = anrufendes Rufzeichen · {dest-name} = QRZ-Vorname · {dest-loc} = QRZ-Ort · {rssi} · {snr} · {hw} = Hardware · {route} = Relayweg · {hops} = Anzahl Hops · {date} · {time}",
                        "{version} = version · {mycall} = own callsign · {callsign} = caller's callsign · {dest-name} = QRZ first name · {dest-loc} = QRZ location · {rssi} · {snr} · {hw} = hardware · {route} = relay path · {hops} = hop count · {date} · {time}",
                        "{version} = versione · {mycall} = nominativo · {callsign} = nominativo chiamante · {dest-name} = nome QRZ · {dest-loc} = luogo QRZ · {rssi} · {snr} · {hw} = hardware · {route} = percorso relay · {hops} = hop · {date} · {time}",
                        "{version} = versión · {mycall} = indicativo propio · {callsign} = indicativo llamante · {dest-name} = nombre QRZ · {dest-loc} = lugar QRZ · {rssi} · {snr} · {hw} = hardware · {route} = ruta relay · {hops} = saltos · {date} · {time}")</span>
                </div>

                <label>@Loc.T("Test-Rufzeichen", "Test Callsign", "Nominativo di test", "Indicativo de prueba")</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <input type="text" @bind="_autoReplyTestCallsign" placeholder="z.B. DH1FR-2" style="flex:1" />
                    <button class="btn-send-now" @onclick="SendAutoReplyTestAsync" disabled="@(_autoReplySending || string.IsNullOrWhiteSpace(_autoReplyTestCallsign))">
                        @if (_autoReplySending)
                        {
                            <span>⏳ @Loc.T("Wird gesendet…", "Sending…", "Invio in corso…", "Enviando…")</span>
                        }
                        else
                        {
                            <span>📤 @Loc.T("Auto-Reply testen", "Test Auto-Reply", "Testa auto-risposta", "Probar auto-respuesta")</span>
                        }
                    </button>
                </div>
                @if (_autoReplyResult != null)
                {
                    <span></span>
                    <div class="@(_autoReplyResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0">
                        @_autoReplyResult
                    </div>
                }
            </div>
        </div>

        <!-- Bake / Beacon -->
        <div class="settings-section">
            <h2 class="settings-section-title">📡 @Loc.T("Bake (Beacon)", "Beacon", "Beacon", "Baliza")</h2>
            <div class="settings-grid">
                <label>@Loc.T("Bake aktiv", "Beacon Active", "Beacon attivo", "Baliza activa")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.BeaconEnabled" />
                    <span>@(_model.BeaconEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>@Loc.T("Gruppe", "Group", "Gruppo", "Grupo")</label>
                <input type="text" @bind="_model.BeaconGroup" placeholder="#262" />

                <label>@Loc.T("Bakentext", "Beacon Text", "Testo beacon", "Texto de baliza")</label>
                <div class="settings-input-hint">
                    <input type="text" @bind="_model.BeaconText" />
                    <span class="settings-hint">@Loc.T("{version} wird durch die aktuelle Versionsnummer ersetzt.", "{version} is replaced with the current version number.", "{version} viene sostituito con il numero di versione.", "{version} se reemplaza con el número de versión.")</span>
                </div>

                <label>@Loc.T("Interval (Stunden, min. 1)", "Interval (Hours, min. 1)", "Intervallo (ore, min. 1)", "Intervalo (horas, mín. 1)")</label>
                <input type="number" min="1" @bind="_model.BeaconIntervalHours" />

                <label>@Loc.T("Bake testen", "Test Beacon", "Testa beacon", "Probar baliza")</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <button class="btn-send-now" @onclick="SendBeaconNowAsync" disabled="@(_beaconSending || string.IsNullOrWhiteSpace(_model.BeaconGroup) || string.IsNullOrWhiteSpace(_model.BeaconText))">
                        @if (_beaconSending)
                        {
                            <span>⏳ @Loc.T("Wird gesendet…", "Sending…", "Invio in corso…", "Enviando…")</span>
                        }
                        else
                        {
                            <span>📡 @Loc.T("Bake jetzt senden", "Send Beacon Now", "Invia beacon ora", "Enviar baliza ahora")</span>
                        }
                    </button>
                </div>
                @if (_beaconResult != null)
                {
                    <span></span>
                    <div class="@(_beaconResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0">
                        @_beaconResult
                    </div>
                }
            </div>
        </div>

        <!-- Telemetrie / Telemetry -->
        <div class="settings-section">
            <h2 class="settings-section-title">📊 @Loc.T("Telemetrie", "Telemetry", "Telemetria", "Telemetría")</h2>
            <div class="settings-grid">
                <label>@Loc.T("Telemetrie aktiv", "Telemetry Active", "Telemetria attiva", "Telemetría activa")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.TelemetryEnabled" />
                    <span>@(_model.TelemetryEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>@Loc.T("JSON-Datei", "JSON File", "File JSON", "Archivo JSON")</label>
                <input type="text" @bind="_model.TelemetryFilePath" placeholder="C:\Temp\telemetry.json" />

                <label>
                    @Loc.T("Ziel", "Target", "Destinatario", "Destino")<br />
                    <small>@Loc.T("(Gruppe z.\u00a0B. #262, * für Alle, oder Rufzeichen)", "(Group e.\u00a0g. #262, * for all, or callsign)", "(Gruppo es. #262, * per tutti, o nominativo)", "(Grupo p.ej. #262, * para todos, o indicativo)")</small>
                </label>
                <input type="text" @bind="_model.TelemetryGroup" placeholder="#262 / * / OE1KBC-1" />

                <label>
                    @Loc.T("Sendezeiten (Stunden 0\u201323)", "Send times (hours 0\u201323)", "Orari di invio (ore 0\u201323)", "Horarios de envío (horas 0\u201323)")<br />
                    <small>@Loc.T("Kommagetrennt, z.\u00a0B. 11,15 f\u00fcr 11:00 und 15:00 Uhr", "Comma-separated, e.\u00a0g. 11,15 for 11:00 and 15:00", "Separati da virgola, es. 11,15 per 11:00 e 15:00", "Separados por coma, p.ej. 11,15 para 11:00 y 15:00")</small>
                </label>
                <input type="text" @bind="_model.TelemetryScheduleHours" placeholder="11,15" />

                <label>@Loc.T("HTTP-API aktiv", "HTTP-API Active", "HTTP-API attiva", "HTTP-API activa")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.TelemetryApiEnabled" />
                    <span>@(_model.TelemetryApiEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>
                    API-Key<br />
                    <small>@Loc.T("(leer\u00a0= keine Authentifizierung)", "(empty\u00a0= no authentication)", "(vuoto = nessuna autenticazione)", "(vacío = sin autenticación)")</small>
                </label>
                <input type="password" @bind="_model.TelemetryApiKey" autocomplete="new-password"
                       placeholder="@Loc.T("Geheimer Schlüssel für POST /api/telemetry", "Secret key for POST /api/telemetry", "Chiave segreta per POST /api/telemetry", "Clave secreta para POST /api/telemetry")" />
            </div>

            <div style="margin-top:1rem">
                <h3 style="font-size:1rem;margin-bottom:0.5rem">@Loc.T("Messwert-Zuordnung", "Measurement Mapping", "Mappatura misure", "Asignación de medidas")</h3>
                <p><small>@Loc.T("JSON-Key: Schlüssel aus der JSON-Datei. Bezeichnung: Anzeigename in der Nachricht. Einheit: z.\u00a0B. °C, kW, hPa. Dez.: Nachkommastellen.", "JSON-Key: key from the JSON file. Label: display name in the message. Unit: e.\u00a0g. °C, kW, hPa. Dec.: decimal places.", "JSON-Key: chiave dal file. Etichetta: nome nel messaggio. Unità: es. °C, kW, hPa. Dec.: decimali.", "JSON-Key: clave del archivo. Etiqueta: nombre en el mensaje. Unidad: p.ej. °C, kW, hPa. Dec.: decimales.")</small></p>
                <table class="telemetry-mapping-table">
                    <thead>
                        <tr>
                            <th>JSON-Key</th>
                            <th>@Loc.T("Bezeichnung", "Label", "Etichetta", "Etiqueta")</th>
                            <th>@Loc.T("Einheit", "Unit", "Unità", "Unidad")</th>
                            <th>@Loc.T("Dez.", "Dec.", "Dec.", "Dec.")</th>
                            <th>@Loc.T("Karte", "Map", "Mappa", "Mapa")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _model.TelemetryMapping)
                        {
                            var e = entry;
                            <tr @key="e">
                                <td><input type="text" @bind="e.JsonKey" /></td>
                                <td><input type="text" @bind="e.Label" /></td>
                                <td><input type="text" @bind="e.Unit" /></td>
                                <td><input type="number" min="0" max="4" style="width:4rem" @bind="e.Decimals" /></td>
                                <td>
                                    <select @bind="e.WeatherRole" title="@Loc.T("Karten-Rolle für Wetter-Popup", "Map role for weather popup", "Ruolo mappa per popup meteo", "Rol de mapa para popup meteorológico")">
                                        <option value="">–</option>
                                        <option value="temp">🌡️ @Loc.T("Temp.", "Temp.", "Temp.", "Temp.")</option>
                                        <option value="humidity">💧 @Loc.T("Feuchte", "Humidity", "Umidità", "Humedad")</option>
                                        <option value="pressure">🧭 @Loc.T("Druck", "Pressure", "Pressione", "Presión")</option>
                                    </select>
                                </td>
                                <td><button type="button" class="btn-remove" @onclick="() => _model.TelemetryMapping.Remove(e)">🗑️</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="button" class="btn-add" @onclick="() => _model.TelemetryMapping.Add(new TelemetryMappingEntry())">➕ @Loc.T("Zeile hinzufügen", "Add Row", "Aggiungi riga", "Agregar fila")</button>
            </div>

            <!-- Vorschau -->
            <div style="margin-top:1.25rem">
                <h3 style="font-size:1rem;margin-bottom:0.5rem">🔍 @Loc.T("Vorschau aktueller Telemetriedaten", "Preview Current Telemetry Data", "Anteprima telemetria attuale", "Vista previa de telemetría actual")</h3>
                <button type="button" class="btn-add" @onclick="LoadTelemetryPreviewAsync">🔄 @Loc.T("Datei lesen & Vorschau", "Read File & Preview", "Leggi file & Anteprima", "Leer archivo & Vista previa")</button>

                @if (_telemetryPreviewError != null)
                {
                    <div style="color:#f85149;margin-top:0.5rem;font-size:13px">❌ @_telemetryPreviewError</div>
                }

                @if (_telemetryPreview != null)
                {
                    <table class="telemetry-mapping-table" style="margin-top:0.75rem">
                        <thead>
                            <tr><th>JSON-Key</th><th>@Loc.T("Aktueller Wert", "Current Value", "Valore attuale", "Valor actual")</th><th>@Loc.T("Gesendet als", "Sent as", "Inviato come", "Enviado como")</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _telemetryPreview)
                            {
                                var fmtStyle = row.IsWarning ? "color:#e3b341" : "color:#3fb950";
                                <tr>
                                    <td>@row.Key</td>
                                    <td style="font-family:monospace">@row.RawValue</td>
                                    <td style="font-family:monospace;@fmtStyle">@row.Formatted</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (_telemetryMessages?.Count > 0)
                    {
                        <div style="margin-top:0.75rem">
                            <strong style="font-size:13px">@Loc.T("Vorschau LoRa-Nachricht", "Preview LoRa Message", "Anteprima messaggio LoRa", "Vista previa mensaje LoRa")@(_telemetryMessages!.Count > 1 ? Loc.T("en", "s", "", "s") : ""):</strong>
                            @foreach (var msg in _telemetryMessages)
                            {
                                <div style="font-family:monospace;background:#16213e;color:#c9d1d9;padding:5px 10px;border-radius:4px;margin-top:4px;font-size:12px;word-break:break-all">
                                    @msg
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <div style="margin-top:1rem">
                <button class="btn-send-now" @onclick="SendTelemetryNowAsync" disabled="@_sendingNow">
                    @if (_sendingNow)
                    {
                        <span>⏳ @Loc.T("Wird gesendet…", "Sending…", "Invio in corso…", "Enviando…")</span>
                    }
                    else
                    {
                        <span>📡 @Loc.T("Telemetrie jetzt senden", "Send Telemetry Now", "Invia telemetria ora", "Enviar telemetría ahora")</span>
                    }
                </button>
                @if (_sendResult != null)
                {
                    <div class="@(_sendResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0.5rem">
                        @_sendResult
                    </div>
                }
            </div>
        </div>

        <!-- Sprache / Language -->
        <div class="settings-section">
            <h2 class="settings-section-title">🌐 @Loc.T("Sprache", "Language", "Lingua", "Idioma")</h2>
            <div class="settings-grid">
                <label>@Loc.T("Oberflächensprache", "UI Language", "Lingua interfaccia", "Idioma de la interfaz")</label>
                <select @bind="_model.Language">
                    <option value="de">🇩🇪 Deutsch</option>
                    <option value="en">🇬🇧 English</option>
                    <option value="it">🇮🇹 Italiano</option>
                    <option value="es">🇪🇸 Español</option>
                </select>
            </div>
        </div>

        <!-- Datenbank / Database (Beta) -->
        <div class="settings-section">
            <h2 class="settings-section-title">🗄️ @Loc.T("Datenbank (Beta)", "Database (Beta)", "Database (Beta)", "Base de datos (Beta)")</h2>
            <div class="settings-notice" style="background:#1a2535;border-color:#3a5a8a;margin-bottom:0.75rem">
                🔒 @Loc.T(
                    "Alle Monitor-Einträge (Rufzeichen, Nachrichtentexte, GPS, RSSI) werden in die externe Datenbank geschrieben. Nur im eigenen, abgesicherten Netz betreiben. Datenschutz beachten.",
                    "All monitor entries (callsigns, message texts, GPS, RSSI) are written to the external database. Only operate in your own secured network. Consider privacy implications.",
                    "Tutte le voci monitor vengono scritte nel database esterno. Usare solo in rete protetta. Considerare la privacy.",
                    "Todas las entradas del monitor se escriben en la base de datos externa. Solo usar en red propia y segura. Considerar la privacidad.")
            </div>
            <div class="settings-grid">
                <label>@Loc.T("Anbieter", "Provider", "Provider", "Proveedor")</label>
                <select @bind="_model.DbProvider" @bind:after="ResetDbTestState">
                    <option value="@DatabaseSettings.ProviderNone">@Loc.T("Deaktiviert", "Disabled", "Disabilitato", "Desactivado")</option>
                    <option value="@DatabaseSettings.ProviderMySql">MySQL / MariaDB</option>
                    <option value="@DatabaseSettings.ProviderInfluxDb">InfluxDB 2</option>
                </select>

                @if (_model.DbProvider == DatabaseSettings.ProviderMySql)
                {
                    <label>
                        @Loc.T("Verbindungsstring", "Connection String", "Stringa di connessione", "Cadena de conexión")<br />
                        <small>z.B. Server=localhost;Database=meshcom;User=mc;Password=secret;</small>
                    </label>
                    <input type="password" autocomplete="new-password" @bind="_model.DbMySqlConnectionString"
                           placeholder="Server=localhost;Database=meshcom;User=mc;Password=..." />

                    <label>@Loc.T("Tabellenname", "Table Name", "Nome tabella", "Nombre de tabla")</label>
                    <input type="text" @bind="_model.DbMySqlTableName" placeholder="meshcom_monitor" />
                }

                @if (_model.DbProvider == DatabaseSettings.ProviderInfluxDb)
                {
                    <label>URL</label>
                    <input type="text" @bind="_model.DbInfluxUrl" placeholder="http://localhost:8086" />

                    <label>Token</label>
                    <input type="password" autocomplete="new-password" @bind="_model.DbInfluxToken" />

