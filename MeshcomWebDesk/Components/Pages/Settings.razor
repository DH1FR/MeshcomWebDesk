        public string TelemetryApiKey        { get; set; } = string.Empty;
        public string Language               { get; set; } = "de";

        // Database
        public string DbProvider              { get; set; } = DatabaseSettings.ProviderNone;
        public string DbMySqlConnectionString { get; set; } = string.Empty;
        public string DbMySqlTableName        { get; set; } = "meshcom_monitor";
        public string DbInfluxUrl             { get; set; } = "http://localhost:8086";
        public string DbInfluxToken           { get; set; } = string.Empty;
        public string DbInfluxOrg             { get; set; } = "meshcom";
        public string DbInfluxBucket          { get; set; } = "meshcom";
        public bool   DbLogInserts            { get; set; }

        // Webhook
        public bool   WebhookEnabled     { get; set; }
        public string WebhookUrl         { get; set; } = string.Empty;
        public bool   WebhookOnMessage   { get; set; } = true;
        public bool   WebhookOnPosition  { get; set; }
        public bool   WebhookOnTelemetry { get; set; }

        // QRZ.com
        public bool   QrzEnabled         { get; set; }
        public string QrzUsername        { get; set; } = string.Empty;
        public string QrzPassword        { get; set; } = string.Empty;
        public bool   QrzLogRequests     { get; set; }
        public int    QrzCacheMaxAgeDays { get; set; } = 30;

        public DatabaseSettings ToDbSettings() => new()
        {
            Provider              = DbProvider,
            MySqlConnectionString = DbMySqlConnectionString,
            MySqlTableName        = DbMySqlTableName,
            InfluxUrl             = DbInfluxUrl,
            InfluxToken           = DbInfluxToken,
            InfluxOrg             = DbInfluxOrg,
            InfluxBucket          = DbInfluxBucket,
            LogInserts            = DbLogInserts
        };

        public MeshcomSettings ToSettings() => new()
        {
            ListenIp            = ListenIp,
            ListenPort          = ListenPort,
            DeviceIp            = DeviceIp,
            DevicePort          = DevicePort,
            MyCallsign          = MyCallsign,
            LogPath             = LogPath,
            LogRetainDays       = LogRetainDays,
            LogUdpTraffic       = LogUdpTraffic,
            MonitorMaxMessages  = MonitorMaxMessages,
            GroupFilterEnabled  = GroupFilterEnabled,
            Groups              = GroupsText
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList(),
            DataPath            = DataPath,
            TimeOffsetHours     = TimeOffsetHours,
            AutoReplyEnabled    = AutoReplyEnabled,
            AutoReplyText       = AutoReplyText,
            BeaconEnabled       = BeaconEnabled,
            BeaconGroup         = BeaconGroup,
            BeaconText          = BeaconText,
            BeaconIntervalHours = BeaconIntervalHours < 1 ? 1 : BeaconIntervalHours,
            TelemetryEnabled       = TelemetryEnabled,
            TelemetryFilePath      = TelemetryFilePath,
            TelemetryGroup         = TelemetryGroup,
            TelemetryScheduleHours = TelemetryScheduleHours,
            TelemetryMapping       = TelemetryMapping,
            TelemetryApiEnabled    = TelemetryApiEnabled,
            TelemetryApiKey        = TelemetryApiKey,
            Language               = Language,
            Database               = ToDbSettings(),
            Webhook = new WebhookSettings
            {
                Enabled     = WebhookEnabled,
                Url         = WebhookUrl,
                OnMessage   = WebhookOnMessage,
                OnPosition  = WebhookOnPosition,
                OnTelemetry = WebhookOnTelemetry
            },
            Qrz = new MeshcomWebDesk.Models.QrzSettings
            {
                Enabled         = QrzEnabled,
                Username        = QrzUsername,
                Password        = QrzPassword,
                LogRequests     = QrzLogRequests,
                CacheMaxAgeDays = QrzCacheMaxAgeDays
            }
        };
    }
}
