    private async Task SetupDbAsync()
    {
        if (_dbTestResult is null) return;
        _dbSetupError = null;
        _dbSettingUp  = true;
        try
        {
            var error = await DatabaseSetupService.SetupAsync(_model.ToDbSettings(), _dbTestResult);
