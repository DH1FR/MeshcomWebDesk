    private List<TelemetryPreviewRow>? _telemetryPreview;
    private List<string>? _telemetryMessages;
    private string? _telemetryPreviewError;

    private sealed record TelemetryPreviewRow(string Key, string RawValue, string Formatted, bool IsWarning);

    private async Task LoadTelemetryPreviewAsync()
    {
        _telemetryPreview      = null;
        _telemetryMessages     = null;
        _telemetryPreviewError = null;

        var filePath = _model.TelemetryFilePath;
        if (string.IsNullOrWhiteSpace(filePath))
        {
            _telemetryPreviewError = Loc.T("Kein Dateipfad konfiguriert.", "No file path configured.", "Nessun percorso file configurato.", "No hay ruta de archivo configurada.");
            return;
        }
        if (!File.Exists(filePath))
        {
            _telemetryPreviewError = Loc.T($"Datei nicht gefunden: {filePath}", $"File not found: {filePath}", $"File non trovato: {filePath}", $"Archivo no encontrado: {filePath}");
            return;
        }

        try
        {
            var content = await File.ReadAllTextAsync(filePath);
            using var doc = System.Text.Json.JsonDocument.Parse(content);
            var root = doc.RootElement;

            var rows  = new List<TelemetryPreviewRow>();
            var parts = new List<string>();

            foreach (var entry in _model.TelemetryMapping)
            {
                if (string.IsNullOrWhiteSpace(entry.JsonKey)) continue;

                if (!root.TryGetProperty(entry.JsonKey, out var valueProp))
                {
                    rows.Add(new(entry.JsonKey, "–", Loc.T("⚠️ Key nicht in Datei", "⚠️ Key not found in file", "⚠️ Chiave non trovata nel file", "⚠️ Clave no encontrada"), true));
                    continue;
                }

                double value;
                if (valueProp.ValueKind == System.Text.Json.JsonValueKind.Number)
                    value = valueProp.GetDouble();
                else if (valueProp.ValueKind == System.Text.Json.JsonValueKind.String &&
                         double.TryParse(valueProp.GetString(),
                             System.Globalization.NumberStyles.Float,
                             System.Globalization.CultureInfo.InvariantCulture, out var parsed))
                    value = parsed;
                else
                {
                    rows.Add(new(entry.JsonKey, valueProp.ToString(), Loc.T("⚠️ Kein Zahlenwert", "⚠️ Not a numeric value", "⚠️ Valore non numerico", "⚠️ Valor no numérico"), true));
                    continue;
                }

                var decimals  = Math.Max(0, entry.Decimals);
                var formatted = value.ToString($"F{decimals}", System.Globalization.CultureInfo.InvariantCulture);
                var label     = string.IsNullOrWhiteSpace(entry.Label) ? entry.JsonKey : entry.Label;
                var part      = $"{label}={formatted}{entry.Unit}";
                rows.Add(new(entry.JsonKey, value.ToString(System.Globalization.CultureInfo.InvariantCulture), part, false));
                parts.Add(part);
            }

            _telemetryPreview = rows;

            // Build message buckets (same logic as MeshcomUdpService)
            const int MaxMsg    = 150;
            const int PrefixMax = 11; // longest prefix e.g. "JN48QN/99:"
            const int BucketLen = MaxMsg - PrefixMax;
            var buckets = new List<string>();
            var current = new System.Text.StringBuilder();
            foreach (var part in parts)
            {
                var sep = current.Length == 0 ? string.Empty : " ";
                if (current.Length + sep.Length + part.Length > BucketLen)
                {
                    if (current.Length > 0) buckets.Add(current.ToString());
                    current.Clear();
                }
                if (current.Length > 0) current.Append(' ');
                current.Append(part);
            }
            if (current.Length > 0) buckets.Add(current.ToString());

            var ownStatus = UdpService.Status;
            var locator   = (ownStatus.OwnLatitude.HasValue && ownStatus.OwnLongitude.HasValue)
                ? MeshcomWebDesk.Helpers.GeoHelper.ToMaidenhead(ownStatus.OwnLatitude.Value, ownStatus.OwnLongitude.Value)
                : null;

            _telemetryMessages = buckets
                .Select((b, i) => buckets.Count == 1
                    ? $"{locator ?? "TM"}: {b}"
                    : $"{locator ?? "TM"}/{i + 1}: {b}")
                .ToList();
        }
        catch (Exception ex)
        {
            _telemetryPreviewError = Loc.T($"Fehler: {ex.Message}", $"Error: {ex.Message}", $"Errore: {ex.Message}", $"Error: {ex.Message}");
        }
    }

    private async Task TestQrzAsync()
    {
        _qrzTesting    = true;
        _qrzTestResult = null;
        try
        {
            // Apply current form credentials temporarily via a scoped settings override
            var saved   = SettingsMonitor.CurrentValue.Qrz;
            var tempSettings = new MeshcomSettings
            {
                Qrz = new MeshcomWebDesk.Models.QrzSettings
                {
                    Enabled  = true,
                    Username = _model.QrzUsername,
                    Password = _model.QrzPassword
                }
            };

            // Save first so QrzService picks up the new credentials
            await SettingsService.SaveMeshcomSettingsAsync(_model.ToSettings());
            QrzService.ClearCache();

            var testCallsign = _model.MyCallsign.Contains('-')
                ? _model.MyCallsign[.._model.MyCallsign.IndexOf('-')]
                : _model.MyCallsign;

            var info = await QrzService.LookupAsync(testCallsign);
            if (info is not null)
                _qrzTestResult = $"✅ {testCallsign}: {info.FirstName} / {info.Location}";
            else
                _qrzTestResult = Loc.T(
                    $"⚠️ Kein Eintrag für {testCallsign} gefunden (Login OK oder Rufzeichen unbekannt).",
                    $"⚠️ No entry found for {testCallsign} (login OK or callsign unknown).",
                    $"⚠️ Nessun risultato per {testCallsign} (login OK o nominativo sconosciuto).",
                    $"⚠️ Sin resultado para {testCallsign} (login OK o indicativo desconocido).");
        }
        catch (Exception ex)
        {
            _qrzTestResult = $"❌ {ex.Message}";
        }
        finally
        {
            _qrzTesting = false;
        }
    }

    private void ClearQrzCacheAsync()
    {
        QrzService.ClearCache();
        _qrzTestResult = Loc.T("✅ Cache geleert.", "✅ Cache cleared.", "✅ Cache svuotata.", "✅ Caché vaciado.");
    }

    private void ResetDbTestState()
    {
        _dbTestResult = null;
        _dbSetupError = null;
    }

    private async Task TestDbConnectionAsync()
    {
        _dbTestResult = null;
        _dbSetupError = null;
        _dbTesting    = true;
        try
        {
            _dbTestResult = await DatabaseSetupService.TestAsync(_model.ToDbSettings());
        }
        finally
        {
            _dbTesting = false;
