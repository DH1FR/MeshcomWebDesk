@page "/"
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using MeshcomWebDesk.Helpers
@using Microsoft.Extensions.Options
@using System.Text.RegularExpressions
@rendermode InteractiveServer
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject LanguageService Loc
@inject QrzService QrzService
@implements IDisposable

<PageTitle>MeshCom Web Client</PageTitle>

<ErrorBoundary>
    <ChildContent>
<div class="meshcom-container">
    @* ===== UPPER AREA: Tabs with conversations ===== *@
    <div class="upper-pane">
        <div class="tab-bar">
            @foreach (var tab in _tabs)
            {
                <button class="tab-button @(tab.Key == _activeTabKey ? "active" : "")"
                        @onclick="() => SelectTab(tab.Key)"
                        title="@(tab.Key != "*" && !tab.Key.StartsWith('#') ? tab.Title + QrzSuffix(tab.Key) : null)">
                    <span class="tab-label-wrap">
                        <span>@(tab.Key == "*" ? Loc.T("Alle", "All", "Tutti", "Todos") : tab.Title)</span>
                        @if (tab.Key != "*" && !tab.Key.StartsWith('#') && QrzFirstName(tab.Key) is { } tabFn)
                        {
                            <span class="tab-qrz-name">@tabFn</span>
                        }
                    </span>
                    @if (tab.UnreadCount > 0)
                    {
                        <span class="tab-unread">@(tab.UnreadCount > 99 ? "99+" : tab.UnreadCount.ToString())</span>
                    }
                    <span class="tab-close" @onclick="() => CloseTab(tab.Key)" @onclick:stopPropagation="true">&times;</span>
                </button>
            }
            <button class="tab-button tab-new" @onclick="ShowNewTabDialog" title="@Loc.T("Neuen Tab öffnen", "Open new tab", "Apri nuova scheda", "Abrir nueva pestaña")">+</button>
        </div>

        @if (_showNewTabInput)
        {
            <div class="new-tab-dialog">
                <input @bind="_newTabCallsign" @bind:event="oninput"
                       placeholder="@Loc.T("Rufzeichen oder Gruppe (z.B. OE1KBC, #gruppe, *)", "Callsign or group (e.g. OE1KBC, #group, *)", "Nominativo o gruppo (es. OE1KBC, #gruppo, *)", "Indicativo o grupo (p.ej. OE1KBC, #grupo, *)") "
                       @onkeydown="OnNewTabKeyDown" />
                <button class="btn-action" @onclick="CreateNewTab">@Loc.T("\u00d6ffnen", "Open", "Apri", "Abrir")</button>
                <button class="btn-cancel" @onclick="() => _showNewTabInput = false">@Loc.T("Abbrechen", "Cancel", "Annulla", "Cancelar")</button>
            </div>
        }

        <div class="tab-content">
            @if (_activeTab != null)
            {
                <div class="message-list" id="tab-messages">
                    @foreach (var msg in _activeTabMessages)
                    {
                        <div class="message @(msg.IsOutgoing ? "msg-out" : "msg-in")">
                            <span class="msg-time">@LT(msg.Timestamp).ToString("HH:mm:ss")</span>
                            @if (msg.IsOutgoing)
                            {
                                <span class="msg-call">@_myCallsign:</span>
                            }
                            else
                            {
                                var msgFn = QrzFirstName(msg.From);
                                <span class="msg-call msg-call-link"
                                      @onclick="() => OpenTabFromMonitor(msg.From)"
                                      title="@(Loc.T($"Chat mit {msg.From} öffnen", $"Open chat with {msg.From}", $"Apri chat con {msg.From}", $"Abrir chat con {msg.From}") + QrzSuffix(msg.From))">@msg.From@if (msgFn is not null){<span class="qrz-badge"> · @msgFn</span>}:</span>
                            }
                            <span class="msg-text">@FormatMessageWithLinks(msg.Text)</span>
                            @if (msg.IsOutgoing)
                            {
                                <span class="@AckCssClass(msg)" title="@AckTooltip(msg)">@AckIcon(msg)</span>
                            }
                        </div>
                    }
                </div>

                <div class="send-bar">
                    <input @bind="_messageText" @bind:event="oninput"
                           placeholder="@Loc.T("Nachricht eingeben...", "Enter message...", "Inserisci messaggio...", "Escribe un mensaje...")"
                           maxlength="149"
                           @onkeydown="OnSendKeyDown" />
                    <span class="char-counter @CharCounterCss">@_messageText.Length/149</span>
                    <button class="btn-send" @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(_messageText) || _messageText.Length > MaxMessageLength)">
                        @Loc.T("Senden", "Send", "Invia", "Enviar")
                    </button>
                </div>
            }
            else
            {
                <div class="no-tab-selected">
                    <p>@Loc.T("Kein Tab ausgewählt. Klicke", "No tab selected. Click", "Nessuna scheda selezionata. Fai clic su", "Ninguna pestaña seleccionada. Haz clic en") <strong>+</strong> @Loc.T("um einen neuen Chat zu öffnen, oder warte auf eine eingehende Nachricht.", "to open a new chat, or wait for an incoming message.", "per aprire una nuova chat, o attendi un messaggio in arrivo.", "para abrir un nuevo chat, o espera un mensaje entrante.")</p>
                </div>
            }
        </div>
    </div>

    <div id="pane-divider" class="pane-divider @(_showMonitor ? "" : "pane-divider-collapsed")"></div>

    @* ===== LOWER AREA: Monitor ===== *@
    <div id="lower-pane" class="lower-pane @(_showMonitor ? "" : "lower-pane-collapsed")">
        <div class="pane-header">
            <span>📡 Monitor</span>
            <span class="msg-count">@_allMessages.Count @Loc.T("Einträge", "Entries", "Voci", "Entradas")</span>
            <button class="mon-toggle-btn" @onclick="ToggleMonitorAsync"
                    title="@(_showMonitor ? Loc.T("Monitor ausblenden", "Hide Monitor", "Nascondi monitor", "Ocultar monitor") : Loc.T("Monitor einblenden", "Show Monitor", "Mostra monitor", "Mostrar monitor"))">
                @(_showMonitor ? "▼" : "▲")
            </button>
        </div>
        <div class="mon-list" id="raw-messages">
            @foreach (var m in _allMessages)
            {
                <div class="mon-row @MonRowClass(m)">
                    <span class="mon-time" title="@(m.MsgId is not null ? $"ID: {m.MsgId}" : null)">@LT(m.Timestamp).ToString("HH:mm:ss")</span>

                    <span class="mon-badge @MonBadgeClass(m)">@MonType(m)</span>

                    <span class="mon-dir @(m.IsOutgoing ? "mon-tx" : "mon-rx")">
                        @(m.IsOutgoing ? "TX" : "RX")
                    </span>

                    @if (!m.IsOutgoing && !string.IsNullOrEmpty(m.SrcType))
                    {
                        <span class="mon-src @SrcTypeCss(m.SrcType)">@SrcTypeLabel(m.SrcType)</span>
                    }

                    @* Routing: From [⟶ Relay1 ⟶ Relay2 …] → To *@
                    @if (!string.IsNullOrEmpty(m.From))
                    {
                        <span class="mon-routing">
                            @if (!string.Equals(m.From, _myCallsign, StringComparison.OrdinalIgnoreCase))
                            {
                                var monFn = QrzFirstName(m.From);
                                <span class="mon-call mon-call-link" @onclick="() => OpenTabFromMonitor(m.From)"
                                      title="@(Loc.T($"Chat mit {m.From} öffnen", $"Open chat with {m.From}", $"Apri chat con {m.From}", $"Abrir chat con {m.From}") + QrzSuffix(m.From))">@m.From@if (monFn is not null){<span class="qrz-badge"> · @monFn</span>}</span>
                            }
                            else
                            {
                                <span class="mon-call">@m.From</span>
                            }
                            @* Show each relay hop inline *@
                            @if (m.RelayPath != null)
                            {
                                foreach (var hop in m.RelayPath.Split(',').Skip(1))
                                {
                                    <span class="mon-relay-arrow">⟶</span>
                                    <span class="mon-relay-node" title="@hop">@hop</span>
                                }
                            }
                            @if (!string.IsNullOrEmpty(m.To))
                            {
                                <span class="mon-arrow">→</span>
                                if (m.IsBroadcast)
                                {
                                    <span class="mon-call mon-bcast">@Loc.T("alle", "all", "tutti", "todos")</span>
                                }
                                else if (!string.Equals(m.To, _myCallsign, StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="mon-call mon-call-link" @onclick="() => OpenTabFromMonitor(m.To)"
                                          title="@(Loc.T($"Chat mit {m.To} öffnen", $"Open chat with {m.To}", $"Apri chat con {m.To}", $"Abrir chat con {m.To}") + QrzSuffix(m.To))">@m.To</span>
                                }
                                else
                                {
                                    <span class="mon-call">@m.To</span>
                                }
                            }
                        </span>
                    }

                    @* Content *@
                    @if (m.IsTelemetry)
                    {
                        <span class="mon-content mon-tele">
                            @if (m.Temp1.HasValue && m.Temp1 != 0)  { <span>🌡️ @m.Temp1.Value.ToString("F1")°C</span> }
                            @if (m.Humidity.HasValue && m.Humidity != 0) { <span class="mon-alt">&nbsp;·&nbsp;💧 @m.Humidity.Value.ToString("F0")%</span> }
                            @if (m.Pressure.HasValue && m.Pressure != 0) { <span class="mon-alt">&nbsp;·&nbsp;🧭 @m.Pressure.Value.ToString("F1") hPa</span> }
                            @if (m.Battery.HasValue) { <span class="mon-alt">&nbsp;·&nbsp;🔋 @m.Battery%</span> }
                        </span>
                    }
                    else if (m.IsPositionBeacon && m.Latitude.HasValue)
                    {
                        <span class="mon-content mon-pos">
                            📍&nbsp;@($"{Math.Abs(m.Latitude.Value):F4}°{(m.Latitude >= 0 ? "N" : "S")}")
                            &nbsp;@($"{Math.Abs(m.Longitude!.Value):F4}°{(m.Longitude >= 0 ? "E" : "W")}")
                            @if (m.Altitude.HasValue)
                            {
                                <span class="mon-alt">&nbsp;·&nbsp;@m.Altitude&nbsp;m</span>
                            }
                            @{ var dist = MonDistance(m); }
                            @if (!string.IsNullOrEmpty(dist))
                            {
                                <span class="mon-dist">&nbsp;·&nbsp;📏&nbsp;@dist</span>
                            }
                            @if (m.Battery.HasValue)
                            {
                                <span class="mon-alt">&nbsp;·&nbsp;🔋 @m.Battery%</span>
                            }
                            @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(m.HwId)))
                            {
                                <span class="mh-hw-badge">&nbsp;@MeshcomLookup.HwName(m.HwId)</span>
                            }
                            @if (!string.IsNullOrEmpty(m.Firmware))
                            {
                                <span class="mh-fw-badge">@m.Firmware</span>
                            }
                        </span>
                    }
                    else if (!string.IsNullOrEmpty(m.Text) && !m.Text.StartsWith('{'))
                    {
                        <span class="mon-content mon-text">"@FormatMessageWithLinks(m.Text)"</span>
                    }
                    else if (string.IsNullOrEmpty(m.From))
                    {
                        <span class="mon-content mon-sys">@MonTruncate(m.RawData, 80)</span>
                    }

                    @* Signal *@
                    @if (m.Rssi.HasValue)
                    {
                        <span class="mon-signal @RssiCssClass(m.Rssi.Value)">
                            @m.Rssi&nbsp;dBm
                            @if (m.Snr.HasValue)
                            {
                                <span class="mon-snr">/ @m.Snr.Value.ToString("F1")&nbsp;dB</span>
                            }
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* ===== STATUS BAR ===== *@
    <div class="status-bar">
        <button class="status-mute-btn @(_soundEnabled ? "" : "status-mute-off")"
                @onclick="() => _soundEnabled = !_soundEnabled"
                title="@(_soundEnabled ? Loc.T("Ton ausschalten", "Mute sound", "Disattiva audio", "Silenciar") : Loc.T("Ton einschalten", "Unmute sound", "Attiva audio", "Activar sonido"))">
            @(_soundEnabled ? "🔔" : "🔕")
        </button>
        <span class="status-sep">|</span>
        <span class="status-item @(_status.IsListening ? "status-ok" : "status-err")">
            @(_status.IsListening ? "🟢" : "🔴") <span class="status-label">UDP @(_status.IsListening ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
        </span>
        <span class="status-sep">|</span>
        <span class="status-item @(_status.IsRegistered ? "status-ok" : "status-warn")">
            @(_status.IsRegistered ? "✅" : "⏳") <span class="status-label">@(_status.IsRegistered ? Loc.T("Registriert", "Registered", "Registrato", "Registrado") : Loc.T("Nicht registriert", "Not registered", "Non registrato", "No registrado"))</span>
        </span>
        <span class="status-sep status-detail">|</span>
        <span class="status-item status-detail">📡 @_settings.DeviceIp:@_settings.DevicePort</span>
        <span class="status-sep">|</span>
        <span class="status-item">🎙️ @_myCallsign</span>
        <span class="status-sep status-detail">|</span>
        <span class="status-item status-detail">📨 RX @_status.RxCount / TX @_status.TxCount</span>
        @if (_status.BeaconActive)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail" title="@Loc.T($"Bake aktiv · Gruppe {_settings.BeaconGroup} · alle {_settings.BeaconIntervalHours} h", $"Beacon active · Group {_settings.BeaconGroup} · every {_settings.BeaconIntervalHours} h", $"Beacon attivo · Gruppo {_settings.BeaconGroup} · ogni {_settings.BeaconIntervalHours} h", $"Baliza activa · Grupo {_settings.BeaconGroup} · cada {_settings.BeaconIntervalHours} h")">
                <span class="beacon-dot">●</span> @Loc.T("Bake", "Beacon", "Beacon", "Baliza")
                @if (_status.BeaconNextSend.HasValue)
                {
                    <span class="@BeaconTimeCss(_status.BeaconNextSend.Value)"> · @_status.BeaconNextSend.Value.ToString("HH:mm")</span>
                }
            </span>
        }
        @if (_status.LastRxTime.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail">⏱️ @LT(_status.LastRxTime.Value).ToString("HH:mm:ss") @Loc.T("von", "from", "da", "de") @_status.LastRxFrom</span>
        }
        @if (_status.LastRssi.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail @RssiCssClass(_status.LastRssi.Value)">
                📶 RSSI @_status.LastRssi dBm&nbsp;&nbsp;SNR @_status.LastSnr?.ToString("F1") dB
            </span>
        }
        @if (_status.LastTxTime.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail">📤 @LT(_status.LastTxTime.Value).ToString("HH:mm:ss")</span>
        }
        @if (_status.OwnLatitude.HasValue && _status.OwnLongitude.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail status-ok">
                📍 @GeoHelper.FormatCoord(_status.OwnLatitude, _status.OwnLongitude)
                @if (_status.OwnAltitude.HasValue)
                {
                    <span class="status-pos-alt">&nbsp;·&nbsp;@_status.OwnAltitude&nbsp;m</span>
                }
            </span>
        }
    </div>
</div>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="padding:1rem;color:#ff6b6b;background:#1a1a2e;border:1px solid #ff6b6b;border-radius:6px;margin:1rem">
            <strong>@Loc.T("Fehler:", "Error:", "Errore:", "Error:")</strong> @ex.Message
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private List<ChatTab> _tabs = [];
    private IReadOnlyList<MeshcomMessage> _allMessages = [];
    private IReadOnlyList<MeshcomMessage> _activeTabMessages = [];
    private readonly Dictionary<string, QrzInfo?> _qrzData = new(StringComparer.OrdinalIgnoreCase);
    private string _activeTabKey = string.Empty;
    private ChatTab? _activeTab;
    private string _messageText = string.Empty;
    private string _newTabCallsign = string.Empty;

    private const int MaxMessageLength = 149;
    private string CharCounterCss => _messageText.Length switch
    {
        >= 145 => "char-danger",
        >= 130 => "char-warn",
        _      => string.Empty
    };
    private bool _showNewTabInput;
    private string _myCallsign = string.Empty;
    private bool _disposed;
    private ConnectionStatus _status = new();
    private MeshcomSettings _settings = new();
    private bool _showMonitor = false;
    private bool _scrollMessages;
    private bool _soundEnabled = true;
    private bool _playSound;
    private bool _isInitialized;
    private DateTime _lastNotificationTime = DateTime.MinValue;

    [Inject] private IConfiguration Configuration { get; set; } = default!;
    [Inject] private IOptions<MeshcomSettings> SettingsOptions { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
        _settings = SettingsOptions.Value;
        _myCallsign = _settings.MyCallsign;
        _status = UdpService.Status;
        ChatService.OnChange += OnChatChanged;
        UdpService.OnStatusChange += OnStatusChanged;
        // Restore active tab from service memory so the first render already shows the correct tab
        _activeTabKey = ChatService.ActiveTabKey;
        RefreshData();
        _isInitialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("meshcomChat.initResizer"); }
            catch (JSException) { }

            // Restore monitor visibility: null = never saved → default visible
            try
            {
                var monVis = await JS.InvokeAsync<bool?>("meshcomChat.getMonitorVisible");
                var targetVisible = monVis ?? true;   // first visit: show monitor
                if (targetVisible != _showMonitor)
                {
                    _showMonitor = targetVisible;
                    StateHasChanged();
                }
            }
            catch (JSException) { }

            // Fallback restore for hard browser reload: ChatService.ActiveTabKey is empty in that case.
            // On normal navigation (Map → Chat) this is a no-op because OnInitialized already
            // read the correct key from ChatService.ActiveTabKey.
            try
            {
                if (string.IsNullOrEmpty(ChatService.ActiveTabKey))
                {
                    var savedKey = await JS.InvokeAsync<string>("meshcomChat.getActiveTab");
                    if (!string.IsNullOrEmpty(savedKey) && _tabs.Any(t => t.Key == savedKey))
                    {
                        _activeTabKey          = savedKey;
                        _activeTab             = ChatService.GetTab(savedKey);
                        _activeTabMessages     = ChatService.GetTabMessages(savedKey);
                        ChatService.ActiveTabKey = savedKey;
                        ChatService.ClearUnread(savedKey);
                        StateHasChanged();
                    }
                }
            }
            catch (JSException) { }

            if (await LoadQrzDataAsync())
                StateHasChanged();
        }

        if (_scrollMessages)
        {
            _scrollMessages = false;
            try { await JS.InvokeVoidAsync("scrollToBottom", "tab-messages"); }
            catch (JSException) { }
        }

        if (_playSound)
        {
            _playSound = false;
            try { await JS.InvokeVoidAsync("playNotificationBeep"); }
            catch (JSException) { }
        }
    }

    private async void OnStatusChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _status = UdpService.Status;
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private async void OnChatChanged()
    {
        if (_disposed) return;

        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                RefreshData();
                StateHasChanged();
            });
            if (await LoadQrzDataAsync() && !_disposed)
                await InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
            // Component may be disposed or circuit disconnected – safe to ignore
        }
    }

    private void RefreshData()
    {
        _tabs = ChatService.Tabs.ToList();
        _allMessages = ChatService.AllMessages;

        // If active tab was closed, select first available
        if (!string.IsNullOrEmpty(_activeTabKey))
        {
            _activeTab = ChatService.GetTab(_activeTabKey);
        }

        if (_activeTab == null && _tabs.Count > 0)
        {
            _activeTabKey = _tabs[0].Key;
            _activeTab = _tabs[0];
        }

        // Create a snapshot of the active tab's messages for thread-safe rendering
        _activeTabMessages = _activeTab != null
            ? ChatService.GetTabMessages(_activeTabKey)
            : [];

        if (!string.IsNullOrEmpty(_activeTabKey))
            ChatService.ClearUnread(_activeTabKey);
        _scrollMessages = true;

        // Sound notification: play beep when a new direct chat message to own callsign arrives.
        // _lastNotificationTime is always updated (even on first load) so that pre-existing
        // saved messages don't trigger the sound after a page reload.
        // Explicitly exclude ACKs, position beacons and telemetry.
        var latestDirect = _allMessages.FirstOrDefault(m =>
            !m.IsOutgoing &&
            !m.IsAck &&
            !m.IsPositionBeacon &&
            !m.IsTelemetry &&
            string.Equals(m.To, _myCallsign, StringComparison.OrdinalIgnoreCase));
        if (latestDirect != null)
        {
            if (_isInitialized && _soundEnabled && latestDirect.Timestamp > _lastNotificationTime)
                _playSound = true;
            _lastNotificationTime = latestDirect.Timestamp;
        }
    }

    private async Task ToggleMonitorAsync()
    {
        _showMonitor = !_showMonitor;
        try { await JS.InvokeVoidAsync("meshcomChat.setMonitorVisible", _showMonitor); }
        catch (JSException) { }
    }

    private void SelectTab(string key)
    {
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _activeTabMessages = ChatService.GetTabMessages(key);
        ChatService.ClearUnread(key);
        ChatService.ActiveTabKey = key;
        _scrollMessages = true;
        _ = JS.InvokeVoidAsync("meshcomChat.setActiveTab", key).AsTask();
    }

    private void CloseTab(string key)
    {
        ChatService.CloseTab(key);
        if (_activeTabKey == key)
        {
            _activeTabKey = string.Empty;
            _activeTab = null;
            ChatService.ActiveTabKey = string.Empty;
            _ = JS.InvokeVoidAsync("meshcomChat.setActiveTab", (object?)null).AsTask();
        }
        RefreshData();
    }

    private void ShowNewTabDialog()
    {
        _showNewTabInput = true;
        _newTabCallsign = string.Empty;
    }

    private void CreateNewTab()
    {
        if (string.IsNullOrWhiteSpace(_newTabCallsign))
            return;

        var key = _newTabCallsign.Trim().ToUpperInvariant();
        ChatService.OpenTab(key);
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _showNewTabInput = false;
        _newTabCallsign = string.Empty;
        RefreshData();
    }

    private void OpenTabFromMonitor(string callsign)
    {
        var key = callsign.Trim().ToUpperInvariant();
        ChatService.OpenTab(key);
        SelectTab(key);
        RefreshData();
    }

    private void OnNewTabKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CreateNewTab();
        else if (e.Key == "Escape")
            _showNewTabInput = false;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_messageText) || _activeTab == null)
            return;

        // Strip leading '#' for group tabs – the node uses the raw group number (e.g. "262"),
        // the '#' is an internal UI convention only.
        // Pass the original tab key so the outgoing message is routed to the correct '#' tab.
        var destination = _activeTab.Key == "*" ? "CQCQCQ" : _activeTab.Key.TrimStart('#');
        await UdpService.SendMessageAsync(destination, _messageText, _activeTab.Key);
        _messageText = string.Empty;
    }

    private async Task OnSendKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }

    private string QrzSuffix(string callsign)
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return string.Empty;
        if (!_qrzData.TryGetValue(callsign, out var info) || info is null) return string.Empty;
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(info.FirstName)) parts.Add(info.FirstName);
        if (!string.IsNullOrEmpty(info.Location))  parts.Add(info.Location);
        return parts.Count > 0 ? " · " + string.Join(", ", parts) : string.Empty;
    }

    private string? QrzFirstName(string callsign)
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return null;
        var fn = _qrzData.GetValueOrDefault(callsign)?.FirstName;
        return string.IsNullOrEmpty(fn) ? null : fn;
    }

    private async Task<bool> LoadQrzDataAsync()
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return false;
        var added = false;
        var callsigns = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var m in _allMessages)
        {
            if (!string.IsNullOrEmpty(m.From) && !m.From.StartsWith('#') && m.From != "*") callsigns.Add(m.From);
            if (!string.IsNullOrEmpty(m.To)   && !m.To.StartsWith('#')   && m.To   != "*") callsigns.Add(m.To);
        }
        foreach (var t in _tabs)
            if (t.Key != "*" && !t.Key.StartsWith('#')) callsigns.Add(t.Key);
        foreach (var cs in callsigns)
        {
            if (_qrzData.ContainsKey(cs)) continue;
            if (QrzService.TryGetCached(cs, out var cached))
                _qrzData[cs] = cached;          // already known – sync, no log entry
            else
            {
                _qrzData[cs] = await QrzService.LookupAsync(cs);   // new callsign, may hit API
                added = true;
            }
        }
        return added;
    }

