@inherits LayoutComponentBase

<div class="app-layout">
    <header class="app-header">
        <div class="app-header-brand">
            <span>📡</span>
            <span class="app-title">MeshCom Web Client</span>
        </div>
        <nav class="app-nav">
            <NavLink class="app-nav-link" href="/" Match="NavLinkMatch.All">💬 Chat</NavLink>
            <NavLink class="app-nav-link" href="/mh">📻 MH</NavLink>
            <NavLink class="app-nav-link" href="/about">ℹ️ Über</NavLink>
