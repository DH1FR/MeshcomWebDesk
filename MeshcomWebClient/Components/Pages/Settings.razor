@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject SettingsService SettingsService
@inject MeshcomUdpService UdpService

<PageTitle>Einstellungen – MeshCom Web Client</PageTitle>

<div class="settings-page">
    <div class="settings-container">

        <div class="settings-header">
            <span class="settings-icon">⚙️</span>
            <h1 class="settings-title">Einstellungen</h1>
        </div>

        <div class="settings-notice">
            ℹ️ Die meisten Einstellungen werden <strong>sofort</strong> übernommen, ohne Neustart.<br />
            Ausnahmen: <strong>Listen-IP / Listen-Port</strong> (Socket-Binding) und
            <strong>Log-Pfad / Log-Aufbewahrung</strong> (Serilog) erfordern einen Neustart der Anwendung.
        </div>

        @if (_saved)
        {
            <div class="settings-success">✅ Einstellungen gespeichert.</div>
        }
        @if (_errorMessage != null)
        {
            <div class="settings-error">❌ Fehler: @_errorMessage</div>
        }

        <!-- Verbindung -->
        <div class="settings-section">
            <h2 class="settings-section-title">🔌 Verbindung</h2>
            <div class="settings-grid">
                <label>Listen IP</label>
                <input type="text" @bind="_model.ListenIp" />

                <label>Listen Port</label>
                <input type="number" min="1" max="65535" @bind="_model.ListenPort" />

                <label>Device IP</label>
                <input type="text" @bind="_model.DeviceIp" />

                <label>Device Port</label>
                <input type="number" min="1" max="65535" @bind="_model.DevicePort" />

                <label>Eigenes Rufzeichen</label>
                <input type="text" @bind="_model.MyCallsign" />
            </div>
        </div>

        <!-- Logging -->
        <div class="settings-section">
            <h2 class="settings-section-title">📝 Logging</h2>
            <div class="settings-grid">
                <label>Log-Pfad</label>
                <input type="text" @bind="_model.LogPath" />

                <label>Log-Aufbewahrung (Tage)</label>
                <input type="number" min="1" @bind="_model.LogRetainDays" />

                <label>UDP-Traffic loggen</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.LogUdpTraffic" />
                    <span>@(_model.LogUdpTraffic ? "Aktiv" : "Inaktiv")</span>
                </label>
            </div>
        </div>

        <!-- Chat & Monitor -->
        <div class="settings-section">
            <h2 class="settings-section-title">💬 Chat &amp; Monitor</h2>
            <div class="settings-grid">
                <label>Monitor-Limit (Einträge)</label>
                <input type="number" min="10" @bind="_model.MonitorMaxMessages" />

                <label>Gruppenfilter aktiv</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.GroupFilterEnabled" />
                    <span>@(_model.GroupFilterEnabled ? "Aktiv" : "Inaktiv")</span>
                </label>

                <label>
                    Gruppen-Whitelist<br />
                    <small>(eine pro Zeile, z.&nbsp;B. #262)</small>
                </label>
                <textarea rows="4" @bind="_model.GroupsText"></textarea>
            </div>
        </div>

        <!-- Datenspeicherung -->
        <div class="settings-section">
            <h2 class="settings-section-title">💾 Datenspeicherung</h2>
            <div class="settings-grid">
                <label>Datenpfad</label>
                <input type="text" @bind="_model.DataPath" />
            </div>
        </div>

        <!-- Auto-Reply -->
        <div class="settings-section">
            <h2 class="settings-section-title">↩️ Auto-Reply</h2>
            <div class="settings-grid">
                <label>Auto-Reply aktiv</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.AutoReplyEnabled" />
                    <span>@(_model.AutoReplyEnabled ? "Aktiv" : "Inaktiv")</span>
                </label>

                <label>Auto-Reply Text</label>
                <input type="text" @bind="_model.AutoReplyText" />
            </div>
        </div>

        <!-- Bake (Beacon) -->
        <div class="settings-section">
            <h2 class="settings-section-title">📡 Bake (Beacon)</h2>
            <div class="settings-grid">
                <label>Bake aktiv</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.BeaconEnabled" />
                    <span>@(_model.BeaconEnabled ? "Aktiv" : "Inaktiv")</span>
                </label>

                <label>Gruppe</label>
                <input type="text" @bind="_model.BeaconGroup" placeholder="#262" />

                <label>Bakentext</label>
                <input type="text" @bind="_model.BeaconText" />

                <label>Interval (Stunden, min. 1)</label>
                <input type="number" min="1" @bind="_model.BeaconIntervalHours" />
            </div>
        </div>

        <!-- Telemetrie -->
        <div class="settings-section">
            <h2 class="settings-section-title">📊 Telemetrie</h2>
            <div class="settings-grid">
                <label>Telemetrie aktiv</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.TelemetryEnabled" />
                    <span>@(_model.TelemetryEnabled ? "Aktiv" : "Inaktiv")</span>
                </label>

                <label>JSON-Datei</label>
                <input type="text" @bind="_model.TelemetryFilePath" placeholder="C:\Temp\telemetry.json" />

                <label>
                    Ziel<br />
                    <small>(Gruppe z.&nbsp;B. #262, * für Alle, oder Rufzeichen)</small>
                </label>
                <input type="text" @bind="_model.TelemetryGroup" placeholder="#262 / * / OE1KBC-1" />

                <label>Interval (Stunden, min. 1)</label>
                <input type="number" min="1" @bind="_model.TelemetryIntervalHours" />

                <label>HTTP-API aktiv</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.TelemetryApiEnabled" />
                    <span>@(_model.TelemetryApiEnabled ? "Aktiv" : "Inaktiv")</span>
                </label>

                <label>
                    API-Key<br />
                    <small>(leer&nbsp;= keine Authentifizierung)</small>
                </label>
                <input type="password" @bind="_model.TelemetryApiKey" autocomplete="new-password"
                       placeholder="Geheimer Schlüssel für POST /api/telemetry" />
            </div>

            <div style="margin-top:1rem">
                <h3 style="font-size:1rem;margin-bottom:0.5rem">Messwert-Zuordnung</h3>
                <p><small>JSON-Key: Schlüssel aus der JSON-Datei. Bezeichnung: Anzeigename in der Nachricht. Einheit: z.&nbsp;B. °C, kW, hPa. Dez.: Nachkommastellen.</small></p>
                <table class="telemetry-mapping-table">
                    <thead>
                        <tr>
                            <th>JSON-Key</th>
                            <th>Bezeichnung</th>
                            <th>Einheit</th>
                            <th>Dez.</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _model.TelemetryMapping)
                        {
                            var e = entry;
                            <tr @key="e">
                                <td><input type="text" @bind="e.JsonKey" /></td>
                                <td><input type="text" @bind="e.Label" /></td>
                                <td><input type="text" @bind="e.Unit" /></td>
                                <td><input type="number" min="0" max="4" style="width:4rem" @bind="e.Decimals" /></td>
                                <td><button type="button" class="btn-remove" @onclick="() => _model.TelemetryMapping.Remove(e)">🗑️</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="button" class="btn-add" @onclick="() => _model.TelemetryMapping.Add(new TelemetryMappingEntry())">➕ Zeile hinzufügen</button>
            </div>

            <!-- Vorschau -->
            <div style="margin-top:1.25rem">
                <h3 style="font-size:1rem;margin-bottom:0.5rem">🔍 Vorschau aktueller Telemetriedaten</h3>
                <button type="button" class="btn-add" @onclick="LoadTelemetryPreviewAsync">🔄 Datei lesen &amp; Vorschau</button>

                @if (_telemetryPreviewError != null)
                {
                    <div style="color:#f85149;margin-top:0.5rem;font-size:13px">❌ @_telemetryPreviewError</div>
                }

                @if (_telemetryPreview != null)
                {
                    <table class="telemetry-mapping-table" style="margin-top:0.75rem">
                        <thead>
                            <tr><th>JSON-Key</th><th>Aktueller Wert</th><th>Gesendet als</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _telemetryPreview)
                            {
                                var fmtStyle = row.IsWarning ? "color:#e3b341" : "color:#3fb950";
                                <tr>
                                    <td>@row.Key</td>
                                    <td style="font-family:monospace">@row.RawValue</td>
                                    <td style="font-family:monospace;@fmtStyle">@row.Formatted</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (_telemetryMessages?.Count > 0)
                    {
                        <div style="margin-top:0.75rem">
                            <strong style="font-size:13px">Vorschau LoRa-Nachricht@(_telemetryMessages!.Count > 1 ? "en" : ""):</strong>
                            @foreach (var msg in _telemetryMessages)
                            {
                                <div style="font-family:monospace;background:#16213e;color:#c9d1d9;padding:5px 10px;border-radius:4px;margin-top:4px;font-size:12px;word-break:break-all">
                                    @msg
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="settings-actions">
            <button class="btn-save" @onclick="SaveAsync">💾 Speichern</button>
            <button class="btn-send-now" @onclick="SendTelemetryNowAsync" disabled="@_sendingNow">
                @if (_sendingNow)
                {
                    <span>⏳ Wird gesendet…</span>
                }
                else
                {
                    <span>📡 Telemetrie jetzt senden</span>
                }
            </button>
        </div>

        @if (_sendResult != null)
        {
            <div class="@(_sendResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0.5rem">
                @_sendResult
            </div>
        }

    </div>
</div>

@code {
    private FormModel _model = new();
    private bool _saved;
    private string? _errorMessage;
    private bool   _sendingNow;
    private string? _sendResult;

    private async Task SendTelemetryNowAsync()
    {
        _sendingNow = true;
        _sendResult = null;
        try
        {
            await UdpService.SendTelemetryNowAsync();
            _sendResult = "✅ Telemetrie gesendet.";
        }
        catch (Exception ex)
        {
            _sendResult = $"❌ Fehler: {ex.Message}";
        }
        finally
        {
            _sendingNow = false;
        }
    }

    private List<TelemetryPreviewRow>? _telemetryPreview;
    private List<string>? _telemetryMessages;
    private string? _telemetryPreviewError;

    private sealed record TelemetryPreviewRow(string Key, string RawValue, string Formatted, bool IsWarning);

    private async Task LoadTelemetryPreviewAsync()
    {
        _telemetryPreview      = null;
        _telemetryMessages     = null;
        _telemetryPreviewError = null;

        var filePath = _model.TelemetryFilePath;
        if (string.IsNullOrWhiteSpace(filePath))
        {
            _telemetryPreviewError = "Kein Dateipfad konfiguriert.";
            return;
        }
        if (!File.Exists(filePath))
        {
            _telemetryPreviewError = $"Datei nicht gefunden: {filePath}";
            return;
        }

        try
        {
            var content = await File.ReadAllTextAsync(filePath);
            using var doc = System.Text.Json.JsonDocument.Parse(content);
            var root = doc.RootElement;

            var rows  = new List<TelemetryPreviewRow>();
            var parts = new List<string>();

            foreach (var entry in _model.TelemetryMapping)
            {
                if (string.IsNullOrWhiteSpace(entry.JsonKey)) continue;

                if (!root.TryGetProperty(entry.JsonKey, out var valueProp))
                {
                    rows.Add(new(entry.JsonKey, "–", "⚠️ Key nicht in Datei", true));
                    continue;
                }

                double value;
                if (valueProp.ValueKind == System.Text.Json.JsonValueKind.Number)
                    value = valueProp.GetDouble();
                else if (valueProp.ValueKind == System.Text.Json.JsonValueKind.String &&
                         double.TryParse(valueProp.GetString(),
                             System.Globalization.NumberStyles.Float,
                             System.Globalization.CultureInfo.InvariantCulture, out var parsed))
                    value = parsed;
                else
                {
                    rows.Add(new(entry.JsonKey, valueProp.ToString(), $"⚠️ Kein Zahlenwert", true));
                    continue;
                }

                var decimals  = Math.Max(0, entry.Decimals);
                var formatted = value.ToString($"F{decimals}", System.Globalization.CultureInfo.InvariantCulture);
                var label     = string.IsNullOrWhiteSpace(entry.Label) ? entry.JsonKey : entry.Label;
                var part      = $"{label}={formatted}{entry.Unit}";
                rows.Add(new(entry.JsonKey, value.ToString(System.Globalization.CultureInfo.InvariantCulture), part, false));
                parts.Add(part);
            }

            _telemetryPreview = rows;

            // Build message buckets (same logic as MeshcomUdpService)
            const int MaxMsg    = 150;
            const int PrefixMax = 11; // longest prefix e.g. "JN48QN/99:"
            const int BucketLen = MaxMsg - PrefixMax;
            var buckets = new List<string>();
            var current = new System.Text.StringBuilder();
            foreach (var part in parts)
            {
                var sep = current.Length == 0 ? string.Empty : " ";
                if (current.Length + sep.Length + part.Length > BucketLen)
                {
                    if (current.Length > 0) buckets.Add(current.ToString());
                    current.Clear();
                }
                if (current.Length > 0) current.Append(' ');
                current.Append(part);
            }
            if (current.Length > 0) buckets.Add(current.ToString());

            var ownStatus = UdpService.Status;
            var locator   = (ownStatus.OwnLatitude.HasValue && ownStatus.OwnLongitude.HasValue)
                ? MeshcomWebClient.Helpers.GeoHelper.ToMaidenhead(ownStatus.OwnLatitude.Value, ownStatus.OwnLongitude.Value)
                : null;

            _telemetryMessages = buckets
                .Select((b, i) => buckets.Count == 1
                    ? $"{locator ?? "TM"}: {b}"
                    : $"{locator ?? "TM"}/{i + 1}: {b}")
                .ToList();
        }
        catch (Exception ex)
        {
            _telemetryPreviewError = $"Fehler: {ex.Message}";
        }
    }

    protected override void OnInitialized()
    {
        var s = SettingsMonitor.CurrentValue;
        _model = new FormModel
        {
            ListenIp            = s.ListenIp,
            ListenPort          = s.ListenPort,
            DeviceIp            = s.DeviceIp,
            DevicePort          = s.DevicePort,
            MyCallsign          = s.MyCallsign,
            LogPath             = s.LogPath,
            LogRetainDays       = s.LogRetainDays,
            LogUdpTraffic       = s.LogUdpTraffic,
            MonitorMaxMessages  = s.MonitorMaxMessages,
            GroupFilterEnabled  = s.GroupFilterEnabled,
            GroupsText          = string.Join("\n", s.Groups),
            DataPath            = s.DataPath,
            AutoReplyEnabled    = s.AutoReplyEnabled,
            AutoReplyText       = s.AutoReplyText,
            BeaconEnabled       = s.BeaconEnabled,
            BeaconGroup         = s.BeaconGroup,
            BeaconText          = s.BeaconText,
            BeaconIntervalHours = s.BeaconIntervalHours,
            TelemetryEnabled       = s.TelemetryEnabled,
            TelemetryFilePath      = s.TelemetryFilePath,
            TelemetryGroup         = s.TelemetryGroup,
            TelemetryIntervalHours = s.TelemetryIntervalHours,
            TelemetryMapping       = s.TelemetryMapping
                .Select(m => new TelemetryMappingEntry
                {
                    JsonKey  = m.JsonKey,
                    Label    = m.Label,
                    Unit     = m.Unit,
                    Decimals = m.Decimals
                })
                .ToList(),
            TelemetryApiEnabled    = s.TelemetryApiEnabled,
            TelemetryApiKey        = s.TelemetryApiKey
        };
    }

    private async Task SaveAsync()
    {
        _saved        = false;
        _errorMessage = null;
        try
        {
            await SettingsService.SaveMeshcomSettingsAsync(_model.ToSettings());
            _saved = true;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private sealed class FormModel
    {
        public string ListenIp            { get; set; } = "0.0.0.0";
        public int    ListenPort          { get; set; } = 1799;
        public string DeviceIp            { get; set; } = "192.168.1.60";
        public int    DevicePort          { get; set; } = 1799;
        public string MyCallsign          { get; set; } = "NOCALL-1";
        public string LogPath             { get; set; } = string.Empty;
        public int    LogRetainDays       { get; set; } = 30;
        public bool   LogUdpTraffic       { get; set; }
        public int    MonitorMaxMessages  { get; set; } = 1000;
        public bool   GroupFilterEnabled  { get; set; }
        public string GroupsText          { get; set; } = string.Empty;
        public string DataPath            { get; set; } = string.Empty;
        public bool   AutoReplyEnabled    { get; set; }
        public string AutoReplyText       { get; set; } = string.Empty;
        public bool   BeaconEnabled       { get; set; }
        public string BeaconGroup         { get; set; } = string.Empty;
        public string BeaconText          { get; set; } = string.Empty;
        public int    BeaconIntervalHours { get; set; } = 1;
        public bool   TelemetryEnabled       { get; set; }
        public string TelemetryFilePath      { get; set; } = string.Empty;
        public string TelemetryGroup         { get; set; } = string.Empty;
        public int    TelemetryIntervalHours { get; set; } = 1;
        public List<TelemetryMappingEntry> TelemetryMapping { get; set; } = [];
        public bool   TelemetryApiEnabled    { get; set; }
        public string TelemetryApiKey        { get; set; } = string.Empty;

        public MeshcomSettings ToSettings() => new()
        {
            ListenIp            = ListenIp,
            ListenPort          = ListenPort,
            DeviceIp            = DeviceIp,
            DevicePort          = DevicePort,
            MyCallsign          = MyCallsign,
            LogPath             = LogPath,
            LogRetainDays       = LogRetainDays,
            LogUdpTraffic       = LogUdpTraffic,
            MonitorMaxMessages  = MonitorMaxMessages,
            GroupFilterEnabled  = GroupFilterEnabled,
            Groups              = GroupsText
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList(),
            DataPath            = DataPath,
            AutoReplyEnabled    = AutoReplyEnabled,
            AutoReplyText       = AutoReplyText,
            BeaconEnabled       = BeaconEnabled,
            BeaconGroup         = BeaconGroup,
            BeaconText          = BeaconText,
            BeaconIntervalHours = BeaconIntervalHours < 1 ? 1 : BeaconIntervalHours,
            TelemetryEnabled       = TelemetryEnabled,
            TelemetryFilePath      = TelemetryFilePath,
            TelemetryGroup         = TelemetryGroup,
            TelemetryIntervalHours = TelemetryIntervalHours < 1 ? 1 : TelemetryIntervalHours,
            TelemetryMapping       = TelemetryMapping,
            TelemetryApiEnabled    = TelemetryApiEnabled,
            TelemetryApiKey        = TelemetryApiKey
        };
    }
}
