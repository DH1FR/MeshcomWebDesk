@page "/"
@using MeshcomWebClient.Models
@using MeshcomWebClient.Services
@using MeshcomWebClient.Helpers
@using Microsoft.Extensions.Options
@rendermode InteractiveServer
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@implements IDisposable

<PageTitle>MeshCom Web Client</PageTitle>

<ErrorBoundary>
    <ChildContent>
<div class="meshcom-container">
    @* ===== UPPER AREA: Tabs with conversations ===== *@
    <div class="upper-pane">
        <div class="tab-bar">
            @foreach (var tab in _tabs)
            {
                <button class="tab-button @(tab.Key == _activeTabKey ? "active" : "")"
                        @onclick="() => SelectTab(tab.Key)">
                    @tab.Title
                    @if (tab.UnreadCount > 0)
                    {
                        <span class="tab-unread">@(tab.UnreadCount > 99 ? "99+" : tab.UnreadCount.ToString())</span>
                    }
                    <span class="tab-close" @onclick="() => CloseTab(tab.Key)" @onclick:stopPropagation="true">&times;</span>
                </button>
            }
            <button class="tab-button tab-new" @onclick="ShowNewTabDialog" title="Neuen Tab öffnen">+</button>
        </div>

        @if (_showNewTabInput)
        {
            <div class="new-tab-dialog">
                <input @bind="_newTabCallsign" @bind:event="oninput"
                       placeholder="Rufzeichen oder Gruppe (z.B. OE1KBC, #gruppe, *)"
                       @onkeydown="OnNewTabKeyDown" />
                <button class="btn-action" @onclick="CreateNewTab">Öffnen</button>
                <button class="btn-cancel" @onclick="() => _showNewTabInput = false">Abbrechen</button>
            </div>
        }

        <div class="tab-content">
            @if (_activeTab != null)
            {
                <div class="message-list" id="tab-messages">
                    @foreach (var msg in _activeTabMessages)
                    {
                        <div class="message @(msg.IsOutgoing ? "msg-out" : "msg-in")">
                            <span class="msg-time">@msg.Timestamp.ToString("HH:mm:ss")</span>
                            <span class="msg-call">@(msg.IsOutgoing ? _myCallsign : msg.From):</span>
                            <span class="msg-text">@msg.Text</span>
                            @if (msg.IsOutgoing)
                            {
                                <span class="@AckCssClass(msg)" title="@AckTooltip(msg)">@AckIcon(msg)</span>
                            }
                        </div>
                    }
                </div>

                <div class="send-bar">
                    <input @bind="_messageText" @bind:event="oninput"
                           placeholder="Nachricht eingeben..."
                           @onkeydown="OnSendKeyDown" />
                    <button class="btn-send" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(_messageText)">
                        Senden
                    </button>
                </div>
            }
            else
            {
                <div class="no-tab-selected">
                    <p>Kein Tab ausgewählt. Klicke <strong>+</strong> um einen neuen Chat zu öffnen,
                       oder warte auf eine eingehende Nachricht.</p>
                </div>
            }
        </div>
    </div>

    @* ===== LOWER AREA: Monitor ===== *@
    <div class="lower-pane @(_showMonitor ? "" : "lower-pane-collapsed")">
        <div class="pane-header">
            <span>📡 Monitor</span>
            <span class="msg-count">@_allMessages.Count Einträge</span>
            <button class="mon-toggle-btn" @onclick="() => _showMonitor = !_showMonitor"
                    title="@(_showMonitor ? "Monitor ausblenden" : "Monitor einblenden")">
                @(_showMonitor ? "▼" : "▲")
            </button>
        </div>
        <div class="mon-list" id="raw-messages">
            @foreach (var m in _allMessages)
            {
                <div class="mon-row @MonRowClass(m)">
                    <span class="mon-time">@m.Timestamp.ToString("HH:mm:ss")</span>

                    <span class="mon-badge @MonBadgeClass(m)">@MonType(m)</span>

                    <span class="mon-dir @(m.IsOutgoing ? "mon-tx" : "mon-rx")">
                        @(m.IsOutgoing ? "TX" : "RX")
                    </span>

                    @* Routing: From → To *@
                    @if (!string.IsNullOrEmpty(m.From))
                    {
                        <span class="mon-routing">
                            <span class="mon-call">@m.From</span>
                            @if (!string.IsNullOrEmpty(m.To))
                            {
                                <span class="mon-arrow">→</span>
                                <span class="mon-call @(m.IsBroadcast ? "mon-bcast" : "")">
                                    @(m.IsBroadcast ? "alle" : m.To)
                                </span>
                            }
                        </span>
                    }

                    @* Content *@
                    @if (m.IsPositionBeacon && m.Latitude.HasValue)
                    {
                        <span class="mon-content mon-pos">
                            📍&nbsp;@($"{Math.Abs(m.Latitude.Value):F4}°{(m.Latitude >= 0 ? "N" : "S")}")
                            &nbsp;@($"{Math.Abs(m.Longitude!.Value):F4}°{(m.Longitude >= 0 ? "E" : "W")}")
                            @if (m.Altitude.HasValue)
                            {
                                <span class="mon-alt">&nbsp;·&nbsp;@m.Altitude&nbsp;m</span>
                            }
                            @{ var dist = MonDistance(m); }
                            @if (!string.IsNullOrEmpty(dist))
                            {
                                <span class="mon-dist">&nbsp;·&nbsp;📏&nbsp;@dist</span>
                            }
                        </span>
                    }
                    else if (!string.IsNullOrEmpty(m.Text) && !m.Text.StartsWith('{'))
                    {
                        <span class="mon-content mon-text">"@m.Text"</span>
                    }
                    else if (string.IsNullOrEmpty(m.From))
                    {
                        <span class="mon-content mon-sys">@MonTruncate(m.RawData, 80)</span>
                    }

                    @* Signal *@
                    @if (m.Rssi.HasValue)
                    {
                        <span class="mon-signal @RssiCssClass(m.Rssi.Value)">
                            @m.Rssi&nbsp;dBm
                            @if (m.Snr.HasValue)
                            {
                                <span class="mon-snr">/ @m.Snr.Value.ToString("F1")&nbsp;dB</span>
                            }
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* ===== STATUS BAR ===== *@
    <div class="status-bar">
        <span class="status-item @(_status.IsListening ? "status-ok" : "status-err")">
            @(_status.IsListening ? "🟢" : "🔴") UDP @(_status.IsListening ? "Aktiv" : "Inaktiv")
        </span>
        <span class="status-sep">|</span>
        <span class="status-item @(_status.IsRegistered ? "status-ok" : "status-warn")">
            @(_status.IsRegistered ? "✅" : "⏳") @(_status.IsRegistered ? "Registriert" : "Nicht registriert")
        </span>
        <span class="status-sep">|</span>
        <span class="status-item">📡 @_settings.DeviceIp:@_settings.DevicePort</span>
        <span class="status-sep">|</span>
        <span class="status-item">🎙️ @_myCallsign</span>
        <span class="status-sep">|</span>
        <span class="status-item">📨 RX @_status.RxCount / TX @_status.TxCount</span>
        @if (_status.LastRxTime.HasValue)
        {
            <span class="status-sep">|</span>
            <span class="status-item">⏱️ @_status.LastRxTime.Value.ToString("HH:mm:ss") von @_status.LastRxFrom</span>
        }
        @if (_status.LastRssi.HasValue)
        {
            <span class="status-sep">|</span>
            <span class="status-item @RssiCssClass(_status.LastRssi.Value)">
                📶 RSSI @_status.LastRssi dBm&nbsp;&nbsp;SNR @_status.LastSnr?.ToString("F1") dB
            </span>
        }
        @if (_status.LastTxTime.HasValue)
        {
            <span class="status-sep">|</span>
            <span class="status-item">📤 @_status.LastTxTime.Value.ToString("HH:mm:ss")</span>
        }
        @if (_status.OwnLatitude.HasValue && _status.OwnLongitude.HasValue)
        {
            <span class="status-sep">|</span>
            <span class="status-item status-ok">
                📍 @GeoHelper.FormatCoord(_status.OwnLatitude, _status.OwnLongitude)
                @if (_status.OwnAltitude.HasValue)
                {
                    <span class="status-pos-alt">&nbsp;·&nbsp;@_status.OwnAltitude&nbsp;m</span>
                }
            </span>
        }
    </div>
</div>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="padding:1rem;color:#ff6b6b;background:#1a1a2e;border:1px solid #ff6b6b;border-radius:6px;margin:1rem">
            <strong>Fehler:</strong> @ex.Message
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private List<ChatTab> _tabs = [];
    private IReadOnlyList<MeshcomMessage> _allMessages = [];
    private IReadOnlyList<MeshcomMessage> _activeTabMessages = [];
    private string _activeTabKey = string.Empty;
    private ChatTab? _activeTab;
    private string _messageText = string.Empty;
    private string _newTabCallsign = string.Empty;
    private bool _showNewTabInput;
    private string _myCallsign = string.Empty;
    private bool _disposed;
    private ConnectionStatus _status = new();
    private MeshcomSettings _settings = new();
    private bool _showMonitor = true;
    private bool _scrollMessages;

    [Inject] private IConfiguration Configuration { get; set; } = default!;
    [Inject] private IOptions<MeshcomSettings> SettingsOptions { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override void OnInitialized()
    {
        _settings = SettingsOptions.Value;
        _myCallsign = _settings.MyCallsign;
        _status = UdpService.Status;
        ChatService.OnChange += OnChatChanged;
        UdpService.OnStatusChange += OnStatusChanged;
        RefreshData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollMessages)
        {
            _scrollMessages = false;
            try
            {
                await JS.InvokeVoidAsync("scrollToBottom", "tab-messages");
            }
            catch (JSException) { }
        }
    }

    private async void OnStatusChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _status = UdpService.Status;
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private async void OnChatChanged()
    {
        if (_disposed) return;

        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                RefreshData();
                StateHasChanged();
            });
        }
        catch (Exception)
        {
            // Component may be disposed or circuit disconnected – safe to ignore
        }
    }

    private void RefreshData()
    {
        _tabs = ChatService.Tabs.ToList();
        _allMessages = ChatService.AllMessages;

        // If active tab was closed, select first available
        if (!string.IsNullOrEmpty(_activeTabKey))
        {
            _activeTab = ChatService.GetTab(_activeTabKey);
        }

        if (_activeTab == null && _tabs.Count > 0)
        {
            _activeTabKey = _tabs[0].Key;
            _activeTab = _tabs[0];
        }

        // Create a snapshot of the active tab's messages for thread-safe rendering
        _activeTabMessages = _activeTab != null
            ? ChatService.GetTabMessages(_activeTabKey)
            : [];

        if (!string.IsNullOrEmpty(_activeTabKey))
            ChatService.ClearUnread(_activeTabKey);
        _scrollMessages = true;
    }

    private void SelectTab(string key)
    {
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _activeTabMessages = ChatService.GetTabMessages(key);
        ChatService.ClearUnread(key);
        _scrollMessages = true;
    }

    private void CloseTab(string key)
    {
        ChatService.CloseTab(key);
        if (_activeTabKey == key)
        {
            _activeTabKey = string.Empty;
            _activeTab = null;
        }
        RefreshData();
    }

    private void ShowNewTabDialog()
    {
        _showNewTabInput = true;
        _newTabCallsign = string.Empty;
    }

    private void CreateNewTab()
    {
        if (string.IsNullOrWhiteSpace(_newTabCallsign))
            return;

        var key = _newTabCallsign.Trim().ToUpperInvariant();
        ChatService.OpenTab(key);
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _showNewTabInput = false;
        _newTabCallsign = string.Empty;
        RefreshData();
    }

    private void OnNewTabKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CreateNewTab();
        else if (e.Key == "Escape")
            _showNewTabInput = false;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_messageText) || _activeTab == null)
            return;

        var destination = _activeTab.Key == "*" ? "CQCQCQ" : _activeTab.Key;
        await UdpService.SendMessageAsync(destination, _messageText);
        _messageText = string.Empty;
    }

    private async Task OnSendKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }

    public void Dispose()
    {
        _disposed = true;
        ChatService.OnChange -= OnChatChanged;
        UdpService.OnStatusChange -= OnStatusChanged;
    }

    private static string RssiCssClass(int rssi) => rssi switch
    {
        > -70 => "rssi-good",
        > -90 => "rssi-fair",
        _ => "rssi-weak"
    };

    // ── Monitor helpers ──────────────────────────────────────────────────────

    private static string MonType(MeshcomMessage m)
    {
        if (m.IsPositionBeacon)            return "POS";
        if (m.IsAck)                       return "ACK";
        if (m.IsOutgoing)                  return "MSG";
        if (!string.IsNullOrEmpty(m.From)) return "MSG";
        return "SYS";
    }

    private static string MonBadgeClass(MeshcomMessage m) => MonType(m) switch
    {
        "POS" => "badge-pos",
        "ACK" => "badge-ack",
        "MSG" when m.IsOutgoing => "badge-tx",
        "MSG" => "badge-msg",
        _ => "badge-sys"
    };

    private static string MonRowClass(MeshcomMessage m) =>
        m.IsOutgoing ? "mon-row-tx" :
        m.IsPositionBeacon ? "mon-row-pos" :
        m.IsAck ? "mon-row-ack" :
        !string.IsNullOrEmpty(m.From) ? "mon-row-msg" :
        "mon-row-sys";

    private static string MonTruncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private string MonDistance(MeshcomMessage m)
    {
        if (!_status.OwnLatitude.HasValue || !_status.OwnLongitude.HasValue ||
            !m.Latitude.HasValue || !m.Longitude.HasValue)
            return string.Empty;

        var km = GeoHelper.CalculateDistanceKm(
            _status.OwnLatitude.Value, _status.OwnLongitude.Value,
            m.Latitude.Value, m.Longitude.Value);
        return GeoHelper.FormatDistance(km);
    }

    private static string AckCssClass(MeshcomMessage m)
    {
        if (m.IsAcknowledged)        return "msg-ack ack-ok";
        if (m.SequenceNumber != null) return "msg-ack ack-sent";
        return "msg-ack ack-pending";
    }

    private static string AckIcon(MeshcomMessage m)
    {
        if (m.IsAcknowledged)        return "✓✓";
        if (m.SequenceNumber != null) return "✓";
        return "⏳";
    }

    private static string AckTooltip(MeshcomMessage m)
    {
        if (m.IsAcknowledged)        return "Zugestellt";
        if (m.SequenceNumber != null) return $"Gesendet (Seq #{m.SequenceNumber})";
        return "Warte auf Node-Echo…";
    }
}
